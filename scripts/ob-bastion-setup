#!/bin/bash
# shellcheck disable=SC2155
#
# ob-bastion-setup - Configure a server as an SSH bastion with LLNG
#
# This script configures a Linux server as an SSH bastion host that:
# - Accepts SSH certificate authentication via LLNG CA
# - Records all sessions using ob-session-recorder
# - Authenticates users via open-bastion PAM module
# - Disables direct sudo access
#
# Copyright (C) 2025 Linagora
# Author: Xavier Guimard <xguimard@linagora.com>
# License: AGPL-3.0

set -euo pipefail

VERSION="0.2.3"
PROG_NAME=$(basename "$0")

# Default configuration
PORTAL_URL=""
# SERVER_GROUP must match a group defined in LLNG (pamAccessServerGroups);
# there is no sensible default, so we leave it empty and prompt for it in
# main() if --server-group was not provided.
SERVER_GROUP=""
SERVER_TOKEN=""
NON_INTERACTIVE=false
VERIFY_SSL=true
TIMEOUT=30
DRY_RUN=false
BACKUP_DIR="/var/backup/open-bastion-setup-$(date +%Y%m%d-%H%M%S)"
MAX_SECURITY=false
KRL_REFRESH_INTERVAL=30
ENABLE_AUDIT_TRACE=false
# Session recording is a core bastion guarantee and is ON by default.
# Pass --disable-session-recorder to opt out (e.g. when recording is handled
# by an external mechanism); this skips recorder configuration and removes
# ForceCommand from the sshd config.
DISABLE_SESSION_RECORDER=false

# OIDC client credentials. CLIENT_ID defaults to "pam-access" inside ob-enroll
# when empty here. CLIENT_SECRET is empty in public-client mode; if the LLNG
# client requires authentication, set it via --client-secret-file or the
# OB_CLIENT_SECRET env var (CLI arg avoided to keep the secret out of /proc).
CLIENT_ID=""
CLIENT_SECRET=""

# Paths
SSH_CA_FILE="/etc/ssh/open-bastion_ca.pub"
SSHD_CONFIG="/etc/ssh/sshd_config"
SSHD_CONFIG_DIR="/etc/ssh/sshd_config.d"
PAM_SSHD="/etc/pam.d/sshd"
OB_CONFIG="/etc/open-bastion/openbastion.conf"
OB_TOKEN="/etc/open-bastion/token"
SESSION_RECORDER="/usr/sbin/ob-session-recorder-wrapper"
SESSION_RECORDER_CONF="/etc/open-bastion/session-recorder.conf"
SSH_REVOKED_KEYS="/etc/ssh/revoked_keys"
PAM_SUDO="/etc/pam.d/sudo"
NSSWITCH_CONF="/etc/nsswitch.conf"
NSS_OB_CONF="/etc/open-bastion/nss_openbastion.conf"

# Hardening (session containment) — see doc/hardening.md
HARDENING_TEMPLATE_DIR="/usr/share/open-bastion/hardening"
HARDENING_LOGIND_DST="/etc/systemd/logind.conf.d/open-bastion.conf"
HARDENING_LIMITS_DST="/etc/security/limits.d/open-bastion.conf"
HARDENING_AT_ALLOW="/etc/at.allow"
HARDENING_CRON_ALLOW="/etc/cron.allow"
ENABLE_HARDENING=false
# Result of setup_hardening, consumed by print_summary. One of:
#   not-applied (default — step never ran or was opt-out)
#   applied     (all sub-steps succeeded)
#   partial     (one or more sub-steps emitted warn/error but step continued)
#   declined    (user said no at the confirm prompt)
#   failed      (hard refusal: templates missing, linger gate, etc.)
#   dry-run     (--dry-run, nothing was actually applied)
HARDENING_RESULT="not-applied"

# Audit trace paths (opt-in, see --enable-audit-trace)
AUDIT_TEMPLATE_DIR="${AUDIT_TEMPLATE_DIR:-/usr/share/open-bastion/audit}"
AUDIT_RULES_FILE="/etc/audit/rules.d/open-bastion.rules"
AUDIT_CRON_FILE="/etc/cron.daily/open-bastion-audit-rotate"

# Result of enroll_server, consumed by print_summary. One of:
#   not-attempted (default — step never ran)
#   success       (enrollment completed; server token stored)
#   token-provided (caller passed --token-file, no portal contact needed)
#   reused        (existing token at $OB_TOKEN adopted, no re-enrollment)
#   dry-run       (--dry-run, no enrollment attempted)
#   failed        (portal contact or device-authorization failed)
ENROLL_RESULT="not-attempted"

# Files created (not just modified) during this run. Used by rollback_on_failure()
# to remove inert config artefacts when the run aborts before SSH lockdown.
# Files we MODIFIED have their originals in BACKUP_DIR via backup_file().
CREATED_FILES=()

# Colors (only if terminal)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    NC=''
fi

info() { echo -e "${GREEN}[INFO]${NC} $*"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*" >&2; }
error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }
step() { echo -e "${BLUE}[STEP]${NC} $*"; }

# Check if running as root
check_root() {
    if [ "$(id -u)" -ne 0 ]; then
        error "This script must be run as root"
        exit 1
    fi
}

# Record a path as something we wrote. Used by rollback_on_failure() to
# decide what to restore from BACKUP_DIR (file existed before — restore)
# vs. what to remove (file did not exist before — delete).
track_created() {
    CREATED_FILES+=("$1")
}

# Rollback inert files written before enrollment, called if enrollment fails
# before SSH/PAM lockdown is applied. Safe because the affected files
# (open-bastion_ca.pub, ob-ssh-principals, openbastion.conf,
# session-recorder.conf) are not referenced by sshd/PAM until later steps.
rollback_on_failure() {
    if [ ${#CREATED_FILES[@]} -eq 0 ]; then
        return 0
    fi
    warn "Rolling back inert files written before enrollment..."
    local f base
    for f in "${CREATED_FILES[@]}"; do
        base=$(basename "$f")
        if [ -f "$BACKUP_DIR/$base" ]; then
            cp -a "$BACKUP_DIR/$base" "$f" && info "Restored $f from backup"
        else
            rm -f "$f" && info "Removed $f (no backup, file did not exist before)"
        fi
    done
    info "Backup directory preserved at: $BACKUP_DIR"
}

# Backup a file before modifying
backup_file() {
    local file="$1"
    if [ -f "$file" ]; then
        mkdir -p "$BACKUP_DIR"
        cp -a "$file" "$BACKUP_DIR/"
        info "Backed up: $file"
    fi
}

# Confirm action (unless non-interactive)
confirm() {
    local msg="$1"
    if [ "$NON_INTERACTIVE" = "true" ]; then
        return 0
    fi

    echo -en "${YELLOW}$msg [y/N] ${NC}"
    read -r response
    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

# Build curl options
build_curl_opts() {
    CURL_OPTS=("-s" "-f" "--connect-timeout" "$TIMEOUT")
    if [ "$VERIFY_SSL" = "false" ]; then
        CURL_OPTS+=("-k")
    fi
}

# Download SSH CA public key
download_ca_key() {
    step "Downloading SSH CA public key from LLNG..."

    build_curl_opts

    local ca_key
    ca_key=$(curl "${CURL_OPTS[@]}" "${PORTAL_URL}/ssh/ca") || {
        error "Failed to download CA public key from ${PORTAL_URL}/ssh/ca"
        error "Make sure sshCaActivation is enabled in LLNG"
        return 1
    }

    if [ -z "$ca_key" ] || [[ ! "$ca_key" =~ ^ssh- ]]; then
        error "Invalid CA public key received"
        return 1
    fi

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would write CA key to $SSH_CA_FILE"
        return 0
    fi

    backup_file "$SSH_CA_FILE"
    echo "$ca_key" > "$SSH_CA_FILE"
    chmod 644 "$SSH_CA_FILE"
    track_created "$SSH_CA_FILE"
    info "CA public key saved to $SSH_CA_FILE"
}

# Install /usr/local/sbin/ob-ssh-principals and its spool directory.
# The script is invoked by sshd as AuthorizedPrincipalsCommand (running as
# nobody); it records the SHA256 fingerprint of the client certificate in
# /run/open-bastion/ssh-fp/<sshd-session-pid>.fp so pam_openbastion can
# forward it to LLNG for the /pam/authorize + /pam/verify fingerprint
# binding (see PamAccess >= 0.1.16).
install_principals_helper() {
    step "Installing SSH principals helper..."

    local script_path="/usr/local/sbin/ob-ssh-principals"
    local spool_dir="/run/open-bastion/ssh-fp"
    local tmpfiles_conf="/etc/tmpfiles.d/open-bastion-ssh-fp.conf"

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would install $script_path and create $spool_dir"
        return 0
    fi

    cat > "$script_path" << 'PRINCIPALS'
#!/bin/sh
# ob-ssh-principals — sshd AuthorizedPrincipalsCommand helper.
# Args: <username> <fingerprint>
# Outputs the username if known (to NSS/local passwd), and writes the
# SSH key fingerprint to /run/open-bastion/ssh-fp/<sshd-session-pid>.fp
# so pam_openbastion can pick it up during pam_acct_mgmt and forward
# it to LLNG.

USERNAME="$1"
FINGERPRINT="$2"
SPOOL_DIR="/run/open-bastion/ssh-fp"

# Record the fingerprint keyed by our sshd-session ancestor PID
# (pam_openbastion converges on the same ancestor by walking /proc).
case "$FINGERPRINT" in
    SHA256:[A-Za-z0-9+/]*) : ;;
    *) FINGERPRINT="" ;;
esac
if [ -n "$FINGERPRINT" ] && [ -d "$SPOOL_DIR" ]; then
    pid=$PPID
    i=0
    while [ "$pid" -gt 1 ] && [ $i -lt 16 ]; do
        comm=$(cat /proc/"$pid"/comm 2>/dev/null || echo "")
        case "$comm" in
            sshd-session|sshd) break ;;
        esac
        pid=$(awk '/^PPid:/ {print $2}' /proc/"$pid"/status 2>/dev/null)
        [ -z "$pid" ] && pid=0
        i=$((i + 1))
    done
    if [ "$pid" -gt 1 ]; then
        umask 077
        tmp=$(mktemp "$SPOOL_DIR/."$pid".XXXXXX" 2>/dev/null) || tmp=""
        if [ -n "$tmp" ]; then
            printf '%s\n' "$FINGERPRINT" > "$tmp"
            mv -f "$tmp" "$SPOOL_DIR/$pid.fp"
        fi
    fi
fi

# Emit the username as allowed principal if it can be resolved
if getent passwd "$USERNAME" >/dev/null 2>&1; then
    echo "$USERNAME"
fi
PRINCIPALS
    chmod 755 "$script_path"
    track_created "$script_path"

    # Spool directory: owned by AuthorizedPrincipalsCommandUser (nobody),
    # mode 0700 so ONLY that user can create/list drops. A world-writable
    # directory (e.g. 1733) would let a local unprivileged user pre-create
    # <pid>.fp with attacker-controlled content; the sticky bit would then
    # prevent the principals helper from overwriting it, and
    # pam_openbastion would read the spoofed fingerprint.
    # pam_openbastion additionally refuses to read the spool if this
    # directory is group/world-writable or if a drop file isn't owned by
    # the directory owner with mode 0600 / nlink 1.
    mkdir -p "$spool_dir"
    chown nobody:nogroup "$spool_dir" 2>/dev/null || chown nobody:nobody "$spool_dir"
    chmod 0700 "$spool_dir"

    # Re-create the spool directory at boot via systemd-tmpfiles.
    cat > "$tmpfiles_conf" << TMPFILES
# Open Bastion SSH fingerprint spool — recreated at boot so the directory
# survives /run wipes. See /usr/local/sbin/ob-ssh-principals.
d /run/open-bastion          0755 root   root   -
d /run/open-bastion/ssh-fp   0700 nobody nogroup -
TMPFILES
    chmod 644 "$tmpfiles_conf"
    track_created "$tmpfiles_conf"

    info "SSH principals helper installed at $script_path"
    info "SSH fingerprint spool prepared at $spool_dir"
}

# Configure sshd
configure_sshd() {
    step "Configuring SSH server..."

    # Build the ForceCommand snippet conditionally.
    local forcecommand_snippet
    if [ "$DISABLE_SESSION_RECORDER" = "true" ]; then
        forcecommand_snippet="# Session recording disabled via --disable-session-recorder"
    else
        forcecommand_snippet="# Record all sessions via LLNG session recorder
ForceCommand $SESSION_RECORDER"
    fi

    local config_content="# LemonLDAP::NG Bastion Configuration
# Generated by $PROG_NAME on $(date)

# Trust LLNG SSH CA for certificate authentication
TrustedUserCAKeys $SSH_CA_FILE

# Accept certificate if principal matches the requested username and drop the
# SSH key fingerprint to /run/open-bastion/ssh-fp/ so pam_openbastion can
# forward it to LLNG (see fingerprint binding on /pam/authorize + /pam/verify).
AuthorizedPrincipalsCommand /usr/local/sbin/ob-ssh-principals %u %f
AuthorizedPrincipalsCommandUser nobody

# Enable public key (certificate) authentication
PubkeyAuthentication yes

# Disable password authentication (use certificates only)
PasswordAuthentication no
KbdInteractiveAuthentication no

# Allow agent forwarding for bastion use
AllowAgentForwarding yes

$forcecommand_snippet

# Enable PAM for authorization
UsePAM yes

# Disable X11 forwarding for security
X11Forwarding no

# Root access via console only (not SSH)
PermitRootLogin no
"

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would create LLNG sshd configuration"
        echo "$config_content"
        return 0
    fi

    # Use sshd_config.d if available (modern systems)
    if [ -d "$SSHD_CONFIG_DIR" ]; then
        # Ensure Include directive exists in main sshd_config
        if ! grep -q "^Include $SSHD_CONFIG_DIR/\*.conf" "$SSHD_CONFIG" 2>/dev/null; then
            backup_file "$SSHD_CONFIG"
            sed -i "1i Include $SSHD_CONFIG_DIR/*.conf" "$SSHD_CONFIG"
            info "Added Include directive to $SSHD_CONFIG"
        fi

        local ob_config="$SSHD_CONFIG_DIR/50-open-bastion-bastion.conf"
        backup_file "$ob_config"
        echo "$config_content" > "$ob_config"
        chmod 644 "$ob_config"
        info "Created $ob_config"
    else
        # Append to main sshd_config
        backup_file "$SSHD_CONFIG"

        # Check if already configured
        if grep -q "TrustedUserCAKeys.*open-bastion" "$SSHD_CONFIG" 2>/dev/null; then
            warn "Open Bastion configuration already exists in $SSHD_CONFIG"
        else
            echo "" >> "$SSHD_CONFIG"
            echo "$config_content" >> "$SSHD_CONFIG"
            info "Added Open Bastion configuration to $SSHD_CONFIG"
        fi
    fi

    # Validate sshd config
    if ! sshd -t 2>/dev/null; then
        error "SSH configuration is invalid!"
        error "Please check the configuration and fix manually"
        return 1
    fi

    info "SSH configuration is valid"
}

# Configure PAM for SSH
configure_pam_sshd() {
    step "Configuring PAM for SSH..."

    local pam_content="# PAM configuration for SSH with LemonLDAP::NG bastion
# Generated by $PROG_NAME on $(date)
#
# Authentication: Handled by SSH certificates (not PAM)
# Authorization: LLNG checks if user can access this bastion
# Session: Standard Unix session handling

# Authentication - permit (handled by SSH certs)
auth       required     pam_permit.so

# Authorization - check with LLNG (certificate-aware mode)
account    required     pam_openbastion.so ssh_cert_aware=true

# Session - create home directory if needed, standard Unix session
session    optional     pam_mkhomedir.so skel=/etc/skel umask=0077
session    required     pam_unix.so
session    optional     pam_openbastion.so
"

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would configure PAM for SSH"
        echo "$pam_content"
        return 0
    fi

    backup_file "$PAM_SSHD"
    echo "$pam_content" > "$PAM_SSHD"
    chmod 644 "$PAM_SSHD"
    info "Configured $PAM_SSHD"
}

# Render openbastion.conf content using current globals. Used both by
# the initial configure_pam_openbastion (Phase 1) and the post-enrollment
# refresh that persists any client_id/client_secret entered during the
# retry prompts.
render_openbastion_conf() {
    printf '# LemonLDAP::NG PAM module configuration\n'
    printf '# Generated by %s on %s\n\n' "$PROG_NAME" "$(date)"
    printf '# Portal URL (required)\n'
    printf 'portal_url = %s\n\n' "$PORTAL_URL"
    printf '# Server authentication token file\n'
    printf 'server_token_file = %s\n\n' "$OB_TOKEN"
    printf '# Server group for authorization rules\n'
    printf 'server_group = %s\n\n' "$SERVER_GROUP"
    # Authorization-only mode: pam_sm_authenticate always succeeds (SSH already
    # validated the cert), only pam_sm_acct_mgmt calls /pam/authorize. Without
    # this, pam_openbastion would require client_id/client_secret in this file
    # for OIDC token introspection — which the bastion never receives, since
    # the user authenticates with an SSH certificate, not an OIDC token.
    printf '# SSH bastion mode: cert auth via sshd, authorization via /pam/authorize\n'
    printf 'authorize_only = true\n\n'
    if [ -n "$CLIENT_ID" ]; then
        printf '# OIDC client used for enrollment (kept for re-enroll)\n'
        printf 'client_id = %s\n\n' "$CLIENT_ID"
    fi
    if [ -n "$CLIENT_SECRET" ]; then
        printf '# OIDC client secret (confidential client; kept for re-enroll)\n'
        printf 'client_secret = %s\n\n' "$CLIENT_SECRET"
    fi
    printf '# HTTP settings\n'
    printf 'timeout = 10\n'
    printf 'verify_ssl = %s\n\n' "$VERIFY_SSL"
    printf '# Cache settings (reduce load on portal)\n'
    printf 'cache_enabled = true\n'
    printf 'cache_dir = /var/cache/open-bastion\n'
    printf 'cache_ttl = 300\n\n'
    printf '# Logging\n'
    printf 'log_level = info\n\n'
    printf '# Audit logging\n'
    printf 'audit_enabled = true\n'
    printf 'audit_to_syslog = true\n'
}

# Configure PAM open-bastion module
configure_pam_openbastion() {
    step "Configuring PAM open-bastion module..."

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would create PAM LLNG configuration"
        render_openbastion_conf
        return 0
    fi

    backup_file "$OB_CONFIG"
    render_openbastion_conf > "$OB_CONFIG"
    chmod 600 "$OB_CONFIG"
    track_created "$OB_CONFIG"
    info "Created $OB_CONFIG"

    # Create cache directory
    mkdir -p /var/cache/open-bastion
    chmod 750 /var/cache/open-bastion
}

# Re-render openbastion.conf in place (no fresh backup, no track) after
# enrollment succeeds — persists credentials updated during retry prompts.
refresh_openbastion_conf() {
    if [ "$DRY_RUN" = "true" ]; then
        return 0
    fi
    render_openbastion_conf > "$OB_CONFIG"
    chmod 600 "$OB_CONFIG"
}

# Configure session recorder
configure_session_recorder() {
    step "Configuring session recorder..."

    # Check if session recorder is installed
    if [ ! -x "$SESSION_RECORDER" ]; then
        warn "Session recorder not found at $SESSION_RECORDER"
        warn "Make sure open-bastion package is installed"
    fi

    local config_content="# LemonLDAP::NG Session Recorder Configuration
# Generated by $PROG_NAME on $(date)

# Directory for session recordings
sessions_dir = /var/lib/open-bastion/sessions

# Recording format (script is always available)
format = script

# Maximum session duration (8 hours)
max_duration = 28800
"

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would create session recorder configuration"
        return 0
    fi

    mkdir -p "$(dirname "$SESSION_RECORDER_CONF")"
    backup_file "$SESSION_RECORDER_CONF"
    echo "$config_content" > "$SESSION_RECORDER_CONF"
    chmod 644 "$SESSION_RECORDER_CONF"
    track_created "$SESSION_RECORDER_CONF"
    info "Created $SESSION_RECORDER_CONF"

    # Create sessions directory.
    # Mode 3771 (drwxrws--t root:ob-sessions):
    #   - setgid (g+s) so per-user subdirs inherit group ob-sessions;
    #   - sticky  (o+t) so only owners can unlink their own entries;
    #   - o+x (no o+r) so a connecting user (not in ob-sessions) can traverse
    #     into its own subdir without being able to list other users' dirs.
    # The o+x is required: after the setgid wrapper drops its elevated gid,
    # the recorder script runs with the user's gid and would otherwise fail to
    # reach its own subdir created by the wrapper.
    mkdir -p /var/lib/open-bastion/sessions
    chgrp ob-sessions /var/lib/open-bastion/sessions
    chmod 3771 /var/lib/open-bastion/sessions
}

# Configure sshd for max security (Mode E)
configure_max_security_sshd() {
    if [ "$MAX_SECURITY" != "true" ]; then
        return 0
    fi

    step "Configuring maximum security SSH settings (Mode E)..."

    local config_content="# Open Bastion Maximum Security Configuration (Mode E)
# Generated by $PROG_NAME on $(date)
#
# SSH: only SSO-signed certificates accepted
# sudo: only via LLNG temporary token (PAM-access)
# KRL: mandatory for certificate revocation

# Disable unsigned key authentication
AuthorizedKeysFile none

# Enable Key Revocation List (mandatory for Mode E)
RevokedKeys $SSH_REVOKED_KEYS

# Expose certificate info for audit
ExposeAuthInfo yes
"

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would create max security sshd configuration"
        echo "$config_content"
        return 0
    fi

    if [ -d "$SSHD_CONFIG_DIR" ]; then
        local max_sec_config="$SSHD_CONFIG_DIR/60-max-security.conf"
        backup_file "$max_sec_config"
        echo "$config_content" > "$max_sec_config"
        chmod 644 "$max_sec_config"
        info "Created $max_sec_config"
    else
        backup_file "$SSHD_CONFIG"
        echo "" >> "$SSHD_CONFIG"
        echo "$config_content" >> "$SSHD_CONFIG"
        info "Added max security configuration to $SSHD_CONFIG"
    fi
}

# Download KRL from LLNG
download_krl() {
    if [ "$MAX_SECURITY" != "true" ]; then
        return 0
    fi

    step "Downloading Key Revocation List (KRL)..."

    build_curl_opts

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would download KRL from ${PORTAL_URL}/ssh/revoked"
        info "[DRY-RUN] Would create cron job for KRL refresh"
        return 0
    fi

    # Download KRL (validate format: must start with "SSHKRL" magic bytes)
    if curl "${CURL_OPTS[@]}" "${PORTAL_URL}/ssh/revoked" -o "${SSH_REVOKED_KEYS}.tmp" 2>/dev/null \
       && head -c 6 "${SSH_REVOKED_KEYS}.tmp" | grep -q "SSHKRL"; then
        mv "${SSH_REVOKED_KEYS}.tmp" "$SSH_REVOKED_KEYS"
        chmod 644 "$SSH_REVOKED_KEYS"
        info "KRL saved to $SSH_REVOKED_KEYS"
    else
        # Create empty revocation file if KRL not available or invalid
        rm -f "${SSH_REVOKED_KEYS}.tmp"
        touch "$SSH_REVOKED_KEYS"
        chmod 644 "$SSH_REVOKED_KEYS"
        warn "KRL not available or invalid format, created empty file"
    fi

    # Create refresh script that reuses curl options (SSL verification, timeout)
    local cron_file="/etc/cron.d/open-bastion-krl"
    local refresh_script="/usr/local/bin/open-bastion-refresh-krl"

    cat > "$refresh_script" << REFRESHEOF
#!/bin/bash
set -euo pipefail
tmp_file=\$(mktemp /tmp/open-bastion-krl.XXXXXX)
trap 'rm -f "\$tmp_file"' EXIT
CURL_OPTS="-sf --connect-timeout ${TIMEOUT}"
if [ "${VERIFY_SSL}" = "false" ]; then
    CURL_OPTS="\$CURL_OPTS -k"
fi
if curl \$CURL_OPTS "${PORTAL_URL}/ssh/revoked" -o "\$tmp_file" \\
   && head -c 6 "\$tmp_file" | grep -q "SSHKRL"; then
    mv "\$tmp_file" "${SSH_REVOKED_KEYS}"
    chmod 644 "${SSH_REVOKED_KEYS}"
fi
REFRESHEOF
    chmod 755 "$refresh_script"

    cat > "$cron_file" << CRONEOF
# Open Bastion KRL refresh (Mode E - Maximum Security)
# Downloads Key Revocation List every ${KRL_REFRESH_INTERVAL} minutes
*/${KRL_REFRESH_INTERVAL} * * * * root ${refresh_script} >/dev/null 2>&1
CRONEOF
    chmod 644 "$cron_file"
    info "Created KRL refresh cron job ($cron_file) every ${KRL_REFRESH_INTERVAL} min"
}

# Configure PAM for sudo with LLNG token (Mode E)
configure_max_security_sudo() {
    if [ "$MAX_SECURITY" != "true" ]; then
        return 0
    fi

    step "Configuring PAM sudo for LLNG token authentication (Mode E)..."

    # shellcheck disable=SC2155
    local pam_content="# PAM configuration for sudo with Open Bastion (Mode E - Maximum Security)
# Generated by $PROG_NAME on $(date)
#
# Authentication: LLNG temporary token ONLY
# - Unix passwords: REJECTED
# - LLNG tokens: REQUIRED (fresh re-authentication via SSO)
#
# Authorization: LLNG checks sudo_allowed flag

auth       sufficient   pam_openbastion.so
auth       required     pam_deny.so

account    required     pam_openbastion.so

session    required     pam_unix.so
"

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would configure PAM sudo for LLNG token auth"
        echo "$pam_content"
        info "[DRY-RUN] Would create group open-bastion-sudo"
        info "[DRY-RUN] Would create /etc/sudoers.d/open-bastion with: %open-bastion-sudo ALL=(ALL) ALL"
        return 0
    fi

    backup_file "$PAM_SUDO"
    echo "$pam_content" > "$PAM_SUDO"
    chmod 644 "$PAM_SUDO"
    info "Configured $PAM_SUDO for LLNG token authentication"

    # Create open-bastion-sudo group for defense-in-depth sudo authorization
    groupadd --system open-bastion-sudo 2>/dev/null || true

    # Configure sudoers: only open-bastion-sudo group members can sudo (PAM also required)
    local sudoers_file="/etc/sudoers.d/open-bastion"
    if [ ! -f "$sudoers_file" ]; then
        echo "# Open Bastion Mode E: defense-in-depth sudo authorization" > "$sudoers_file"
        echo "# Both group membership (managed by PAM session) AND LLNG token are required" >> "$sudoers_file"
        echo "%open-bastion-sudo ALL=(ALL) ALL" >> "$sudoers_file"
        chmod 440 "$sudoers_file"
        info "Created $sudoers_file"
    fi
}

# Ensure /etc/nsswitch.conf has a usable "<db>: files openbastion ..." line.
# Handles three cases:
#   1. Active line already includes "openbastion" → noop.
#   2. Active line exists without openbastion → insert openbastion after the
#      first source token (files / compat / etc.), preserving everything else.
#   3. No active line (missing or commented out) → APPEND a fresh
#      "<db>: files openbastion systemd" line. Crucial fix: previously the
#      script silently no-op'd here, leaving NSS unable to resolve any user.
nss_configure_db() {
    local db="$1"
    local file="$2"
    local default_line="$3"

    if grep -qE "^${db}:.*[[:space:]]openbastion([[:space:]]|\$)" "$file"; then
        info "NSS already configured for $db"
        return 0
    fi

    if grep -qE "^${db}:" "$file"; then
        # Active line present — insert openbastion after the first source token.
        if grep -qE "^${db}:[[:space:]]+files" "$file"; then
            sed -i -E "s/^(${db}:[[:space:]]+files)/\\1 openbastion/" "$file"
        elif grep -qE "^${db}:[[:space:]]+compat" "$file"; then
            sed -i -E "s/^(${db}:[[:space:]]+compat)/\\1 openbastion/" "$file"
        else
            sed -i -E "s/^(${db}:[[:space:]]+[^[:space:]]+)/\\1 openbastion/" "$file"
        fi
        info "Added openbastion to $db in $file"
    else
        # No active "<db>:" line — append a complete one. This fixes systems
        # where nsswitch.conf ships with passwd:/group: commented out (some
        # minimal images and "Example configuration" templates).
        warn "$file has no active '$db:' line; appending: $default_line"
        printf '%s\n' "$default_line" >> "$file"
        info "Appended new $db line to $file"
    fi

    # Sanity check: an active "<db>:" line containing openbastion must now exist.
    if ! grep -qE "^${db}:.*[[:space:]]openbastion([[:space:]]|\$)" "$file"; then
        error "Failed to add openbastion to $db in $file — please edit manually."
        return 1
    fi
}

# Configure NSS for user/group resolution via LLNG
configure_nss() {
    step "Configuring NSS for user/group resolution..."

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would configure NSS"
        return 0
    fi

    backup_file "$NSSWITCH_CONF"

    nss_configure_db passwd "$NSSWITCH_CONF" "passwd:         files openbastion systemd" || return 1
    nss_configure_db group  "$NSSWITCH_CONF" "group:          files openbastion systemd" || return 1

    # Create NSS configuration
    # shellcheck disable=SC2155
    local nss_content="# LemonLDAP::NG NSS module configuration
# Generated by $PROG_NAME on $(date)

# Portal URL
portal_url = $PORTAL_URL

# Server token file
server_token_file = $OB_TOKEN

# Cache settings
cache_enabled = true
cache_ttl = 300

# UID/GID range for dynamic users
min_uid = 10000
max_uid = 60000
min_gid = 10000
max_gid = 60000

# Default shell and home directory
default_shell = /bin/bash
home_base = /home
"

    backup_file "$NSS_OB_CONF"
    echo "$nss_content" > "$NSS_OB_CONF"
    chmod 644 "$NSS_OB_CONF"
    info "Created $NSS_OB_CONF"
}

# Install one hardening template by absolute source/destination path,
# creating the destination directory if missing and backing up any
# existing file. Mode 0644 root:root.
install_hardening_file() {
    local src="$1"
    local dst="$2"
    local dst_dir
    dst_dir=$(dirname "$dst")

    if [ ! -f "$src" ]; then
        warn "Hardening template missing: $src (package not fully installed?)"
        return 1
    fi

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would install $src -> $dst (0644 root:root)"
        return 0
    fi

    [ -d "$dst_dir" ] || mkdir -p "$dst_dir"
    backup_file "$dst"
    install -m 0644 -o root -g root "$src" "$dst"
    info "Installed $dst"
}

# Conditionally drop a *.allow whitelist if absent, keeping any
# pre-existing admin file untouched. We only warn — overwriting an
# admin-managed file silently would be hostile.
install_hardening_allowlist() {
    local src="$1"
    local dst="$2"

    if [ ! -f "$src" ]; then
        warn "Hardening template missing: $src"
        return 1
    fi

    if [ -f "$dst" ]; then
        if cmp -s "$src" "$dst"; then
            info "$dst already matches template, leaving as-is"
        else
            warn "$dst already exists with custom content — leaving untouched"
            warn "Review it manually against $src to ensure containment is preserved"
            # The shipped allow-list was NOT applied; containment may be weaker
            # than intended, so the overall hardening outcome is only partial.
            HARDENING_RESULT="partial"
        fi
        return 0
    fi

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would create $dst from $src (0644 root:root)"
        return 0
    fi

    install -m 0644 -o root -g root "$src" "$dst"
    info "Created $dst"
}

# Detect non-root users that have `loginctl enable-linger` set.
# A lingering user keeps a per-user systemd manager running after
# logout, which lets them schedule deferred work via
#   systemd-run --user --on-active=…
# That bypasses both KillUserProcesses=yes and the at/cron allowlists.
# This function prints offending "<user>:<uid>" lines to stdout (one
# per line, empty if none) and returns 0. It returns 1 only when
# loginctl is missing — callers should treat that as "skip with a
# warning" since a host without systemd cannot enable linger anyway.
detect_lingering_users() {
    if ! command -v loginctl >/dev/null 2>&1; then
        return 1
    fi

    local users_raw
    # `loginctl list-users --no-legend` prints "<uid> <user> [..]" per row.
    # Some versions trail a header/legend even with --no-legend on older
    # systemd; we filter defensively by requiring a leading numeric uid.
    users_raw=$(loginctl list-users --no-legend 2>/dev/null || true)
    [ -n "$users_raw" ] || return 0

    local uid user linger
    while read -r uid user _rest; do
        case "$uid" in
            ''|*[!0-9]*) continue ;;     # skip non-numeric rows / headers
        esac
        [ "$uid" = "0" ] && continue     # root is allowed to linger
        [ -n "$user" ] || continue
        linger=$(loginctl show-user "$user" --property=Linger --value 2>/dev/null || echo "")
        if [ "$linger" = "yes" ]; then
            printf '%s:%s\n' "$user" "$uid"
        fi
    done <<< "$users_raw"

    return 0
}

# Configure host-level session containment. All steps are pure system
# config — no setuid binary is added. See doc/hardening.md for rationale.
setup_hardening() {
    step "Applying session containment hardening..."

    if [ ! -d "$HARDENING_TEMPLATE_DIR" ]; then
        warn "Hardening templates not found in $HARDENING_TEMPLATE_DIR"
        warn "Skipping hardening step — install the open-bastion package."
        HARDENING_RESULT="failed"
        return 1
    fi

    # Pre-flight: refuse to harden if any non-root user has linger
    # enabled. Such a user could schedule jobs via `systemd-run --user`
    # that survive logout, defeating both KillUserProcesses=yes and the
    # at/cron allow-lists. This is a security gate, not a UX one — we
    # fail even in --yes mode. In --dry-run, only log so operators can
    # discover the problem before committing.
    local linger_offenders
    if linger_offenders=$(detect_lingering_users); then
        if [ -n "$linger_offenders" ]; then
            if [ "$DRY_RUN" = "true" ]; then
                warn "[DRY-RUN] Linger enabled for the following non-root users (would abort in real run):"
                while IFS=: read -r u uid; do
                    [ -n "$u" ] || continue
                    warn "[DRY-RUN]   $u (uid $uid)"
                done <<< "$linger_offenders"
            else
                error "Hardening refused: the following users have systemd linger enabled,"
                error "        which would let them schedule deferred jobs via 'systemd-run --user',"
                error "        bypassing this hardening:"
                while IFS=: read -r u uid; do
                    [ -n "$u" ] || continue
                    error "          $u (uid $uid)"
                done <<< "$linger_offenders"
                error ""
                error "        To proceed, disable linger for these users:"
                error "          loginctl disable-linger <user>"
                error ""
                error "        Then re-run: ob-bastion-setup --portal $PORTAL_URL --enable-hardening [...]"
                HARDENING_RESULT="failed"
                return 1
            fi
        fi
    else
        warn "loginctl not available, skipping linger pre-check"
    fi

    if ! confirm "Apply session containment hardening (KillUserProcesses, nproc cap, at/cron allowlists, mask atd)?"; then
        info "Hardening skipped by user"
        HARDENING_RESULT="declined"
        return 0
    fi

    # Optimistic: assume each sub-step will succeed; downgrade to
    # "partial" on any failure that we choose to recover from rather
    # than abort. Final state is reported by print_summary and by the
    # closing log line below.
    HARDENING_RESULT="applied"

    # 1. logind: KillUserProcesses=yes
    if ! install_hardening_file \
            "$HARDENING_TEMPLATE_DIR/logind.conf.d/open-bastion.conf" \
            "$HARDENING_LOGIND_DST"; then
        warn "Failed to install $HARDENING_LOGIND_DST — containment is incomplete"
        HARDENING_RESULT="partial"
    fi

    # 2. limits.d: nproc cap
    if ! install_hardening_file \
            "$HARDENING_TEMPLATE_DIR/security/limits.d/open-bastion.conf" \
            "$HARDENING_LIMITS_DST"; then
        warn "Failed to install $HARDENING_LIMITS_DST — fork-bomb cap not in place"
        HARDENING_RESULT="partial"
    fi

    # 3. at.allow / cron.allow — never overwrite an admin-managed file
    if ! install_hardening_allowlist \
            "$HARDENING_TEMPLATE_DIR/at.allow" \
            "$HARDENING_AT_ALLOW"; then
        warn "Failed to deploy $HARDENING_AT_ALLOW — at(1) lockdown skipped"
        HARDENING_RESULT="partial"
    fi

    if ! install_hardening_allowlist \
            "$HARDENING_TEMPLATE_DIR/cron.allow" \
            "$HARDENING_CRON_ALLOW"; then
        warn "Failed to deploy $HARDENING_CRON_ALLOW — crontab(1) lockdown skipped"
        HARDENING_RESULT="partial"
    fi

    # 3b. Warn if cron.allow doesn't list 'root'. The Mode E KRL refresh
    #     job (/etc/cron.d/open-bastion-krl) runs as root, and cron
    #     refuses to dispatch jobs for users absent from cron.allow when
    #     the file exists. An admin-managed cron.allow without 'root'
    #     would silently break KRL refresh.
    if [ -f "$HARDENING_CRON_ALLOW" ] \
       && ! grep -qE '^[[:space:]]*root[[:space:]]*$' "$HARDENING_CRON_ALLOW"; then
        warn "$HARDENING_CRON_ALLOW exists but does not list 'root' — this will break"
        warn "the KRL refresh job (/etc/cron.d/open-bastion-krl). Add 'root' on its"
        warn "own line to $HARDENING_CRON_ALLOW."
    fi

    # 4. Mask atd if it exists. We do NOT mask cron because
    #    --max-security writes /etc/cron.d/open-bastion-krl which needs
    #    a running cron daemon.
    if systemctl list-unit-files atd.service 2>/dev/null | grep -q '^atd\.service'; then
        if [ "$DRY_RUN" = "true" ]; then
            info "[DRY-RUN] Would systemctl mask atd && systemctl stop atd"
        else
            systemctl stop atd 2>/dev/null || true
            if systemctl mask atd 2>/dev/null; then
                info "Masked atd.service (deferred at(1) jobs disabled)"
            else
                warn "Failed to mask atd.service — at(1) jobs may still run"
                HARDENING_RESULT="partial"
            fi
        fi
    else
        info "atd.service not present, nothing to mask"
    fi

    # 5. Reload logind so KillUserProcesses=yes takes effect.
    #    `systemctl reload` (SIGHUP) is non-disruptive: logind re-reads
    #    its drop-ins without restarting and without killing active
    #    sessions. KillUserProcesses=yes is consulted at session-end
    #    cleanup, so the new behaviour applies to existing sessions
    #    when they eventually log out, while currently-connected admins
    #    keep their shells. Avoid `reload-or-restart` here: a fallback
    #    to restart would terminate every user session, including the
    #    admin running this setup.
    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would systemctl reload systemd-logind (SIGHUP, non-disruptive)"
        # In dry-run, nothing was actually written; report as such so
        # the operator doesn't read "applied" and assume the host is
        # configured.
        HARDENING_RESULT="dry-run"
    else
        info "Reloading systemd-logind (SIGHUP, no session disruption)"
        if systemctl reload systemd-logind 2>/dev/null; then
            info "Reloaded systemd-logind"
        else
            warn "Failed to reload systemd-logind — run 'systemctl reload systemd-logind' manually"
            HARDENING_RESULT="partial"
        fi
    fi

    case "$HARDENING_RESULT" in
        applied)
            info "Hardening applied. Verify with: loginctl show-user <user> | grep Linger"
            ;;
        partial)
            warn "Hardening applied with warnings — review the output above before relying on containment"
            ;;
        dry-run)
            info "[DRY-RUN] Hardening would be applied. Re-run without --dry-run to commit."
            ;;
        *)
            ;;
    esac
}

# Configure primary audit trace via auditd (opt-in).
# Goal: tamper-evident syscall-level evidence of non-sudo user activity,
# independent of the pty session recording (which a malicious user could
# wipe or bypass via setsid/at/cron). Targets auid >= 1000.
#
# Caller decides whether this runs (see ENABLE_AUDIT_TRACE in main()).
# This function never tries to install the auditd package itself: it only
# *configures* an auditd that is already present (Recommends in packaging).
setup_audit_trace() {
    step "Configuring primary audit trace (auditd)..."

    # 1. Sanity: auditd must be installed. We don't try to be clever — both
    #    `auditctl` (the CLI) and `augenrules` (the rules.d compiler) are
    #    needed at runtime. systemctl probe is an additional belt-and-braces.
    local auditd_ok=true
    if ! command -v auditctl >/dev/null 2>&1; then
        auditd_ok=false
    fi
    if ! command -v augenrules >/dev/null 2>&1; then
        auditd_ok=false
    fi
    if [ "$auditd_ok" != "true" ]; then
        warn "auditd is not installed; skipping audit trace setup."
        warn "  To enable audit trace later, install auditd then re-run with --enable-audit-trace:"
        warn "    Debian/Ubuntu: apt install auditd"
        warn "    RHEL/Rocky/Fedora: dnf install audit"
        return 0
    fi

    # 2. Templates must be deployed (CMake installs them under datarootdir).
    local rules_template="$AUDIT_TEMPLATE_DIR/rules.d/open-bastion.rules"
    local cron_template="$AUDIT_TEMPLATE_DIR/cron.daily/open-bastion-audit-rotate"
    if [ ! -f "$rules_template" ]; then
        error "Audit rules template not found: $rules_template"
        error "Reinstall the open-bastion package, or set AUDIT_TEMPLATE_DIR=<path>."
        return 1
    fi
    if [ ! -f "$cron_template" ]; then
        error "Audit cron template not found: $cron_template"
        return 1
    fi

    # 3. Confirmation: this deploys rules.d/cron.daily entries and restarts
    #    auditd. Default-OFF policy applies. /etc/audit/auditd.conf is NOT
    #    touched — see rationale below.
    if ! confirm "Enable primary audit trace? Installs rules.d + cron.daily and restarts auditd."; then
        info "Audit trace setup skipped by user."
        return 0
    fi

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would install $AUDIT_RULES_FILE (0640 root:root)"
        info "[DRY-RUN] Would install $AUDIT_CRON_FILE (0755 root:root)"
        info "[DRY-RUN] Would augenrules --load and restart auditd"
        info "[DRY-RUN] /etc/audit/auditd.conf intentionally NOT modified"
        return 0
    fi

    # 4. Install rules template into /etc/audit/rules.d/.
    #    auditd's default rules.d entries (e.g. audit.rules) ship as 0640
    #    root:root on Debian; we match that.
    #    Guard against `set -e` aborting the whole ob-bastion-setup run if
    #    /etc/audit/rules.d/ is missing, RO, or perms-denied — return 1
    #    instead so main() catches it via `setup_audit_trace || warn …`.
    if ! install -o root -g root -m 0640 "$rules_template" "$AUDIT_RULES_FILE"; then
        error "Failed to install $AUDIT_RULES_FILE"
        return 1
    fi
    info "Installed $AUDIT_RULES_FILE"

    # 5. Install daily rotation cron. cron.daily entries must be executable
    #    and unsuffixed (run-parts ignores files with dots/tildes).
    if ! install -o root -g root -m 0755 "$cron_template" "$AUDIT_CRON_FILE"; then
        error "Failed to install $AUDIT_CRON_FILE"
        return 1
    fi
    info "Installed $AUDIT_CRON_FILE"

    # /etc/audit/auditd.conf is intentionally NOT modified. It is a single
    # admin-tunable file owned by the audit distro package. Drop-in mechanisms
    # (rules.d/, cron.daily/) are used where they exist; auditd.conf is left
    # for the administrator to tune manually (see doc/audit.md).
    info "Audit trace deployed. /etc/audit/auditd.conf is intentionally NOT modified."
    info "For ~1 week retention, set num_logs=7 max_log_file=50 max_log_file_action=ROTATE in /etc/audit/auditd.conf manually (see doc/audit.md)."

    # 6. Compile + load rules. augenrules merges everything under
    #    /etc/audit/rules.d/*.rules into /etc/audit/audit.rules and tells
    #    auditctl to load them. A non-zero exit usually means a bad rule
    #    (e.g. arch mismatch on 32-bit kernel) — surface it but don't abort:
    #    the cron rotation is still in effect.
    if augenrules --load >/dev/null 2>&1; then
        info "auditd rules loaded via augenrules"
    else
        warn "augenrules --load failed; check 'augenrules --check' output."
    fi

    # 7. Restart auditd to activate the new rules.d entries.
    #    auditd does not honour SIGHUP for rules.d changes — restart is the
    #    documented way. Unlike logind, restarting auditd does NOT terminate
    #    SSH sessions, so this is safe to run on a live bastion.
    if systemctl is-active --quiet auditd 2>/dev/null; then
        if systemctl restart auditd 2>/dev/null; then
            info "Restarted auditd.service"
        else
            warn "Failed to restart auditd; run 'systemctl restart auditd' manually."
        fi
    else
        warn "auditd.service is not active; start it with 'systemctl enable --now auditd'."
    fi
}

# Pre-flight: verify the portal's Device Authorization endpoint is reachable
# BEFORE applying any SSH/PAM lockdown. Without this check, a failed
# enrollment could leave the bastion in a state where no one can log in
# (PasswordAuthentication disabled + no certs because no enrollment).
preflight_check_portal() {
    # If user provided a pre-shared token, no portal contact is needed.
    if [ -n "$SERVER_TOKEN" ]; then
        return 0
    fi
    if [ "$DRY_RUN" = "true" ]; then
        return 0
    fi

    step "Pre-flight: checking Device Authorization endpoint reachability..."

    build_curl_opts
    # POST with no body. Any HTTP status (even 400/401/405) means the endpoint
    # exists. A network failure (curl exit != 22 typically yields "000" via -w).
    # We strip "-f" so we get the HTTP code instead of curl returning non-zero on 4xx.
    local opts=()
    local opt
    for opt in "${CURL_OPTS[@]}"; do
        [ "$opt" = "-f" ] || opts+=("$opt")
    done

    local http_code
    http_code=$(curl "${opts[@]}" -X POST -o /dev/null -w '%{http_code}' \
                "${PORTAL_URL}/oauth2/device" 2>/dev/null) || http_code="000"

    if [ "$http_code" = "000" ]; then
        error "Cannot reach Device Authorization endpoint at ${PORTAL_URL}/oauth2/device"
        error "Aborting BEFORE any SSH/PAM lockdown to avoid leaving the bastion unreachable."
        error ""
        error "Possible causes:"
        error "  - Portal URL incorrect (got: $PORTAL_URL)"
        error "  - Device Authorization Grant not enabled on the LLNG portal"
        error "  - Network/DNS/TLS failure (test: curl -v ${PORTAL_URL}/oauth2/device)"
        error "  - Use -k/--insecure if portal uses a self-signed certificate"
        return 1
    fi

    if [ "$http_code" = "404" ]; then
        error "Portal responded with 404 on /oauth2/device — Device Authorization Grant is not enabled."
        error "Enable 'oidcServiceAllowAuthorizationCodeGrant' / Device Flow on the LLNG portal."
        return 1
    fi

    info "Device Authorization endpoint reachable (HTTP $http_code)"
    return 0
}

# Abort if the saved server token has no refresh_token. Without an offline
# refresh token the short-lived access token cannot be renewed, and SSO/NSS
# lookups (getent passwd <user>) stop working ~1h after setup. A missing
# refresh_token means the OIDC client does not grant offline access.
require_refresh_token() {
    [ -s "$OB_TOKEN" ] || return 0
    local rt
    rt=$(jq -r '.refresh_token // ""' "$OB_TOKEN" 2>/dev/null)
    if [ -z "$rt" ]; then
        error "The server token at $OB_TOKEN has NO refresh_token."
        error "The access token cannot be renewed, so SSO/NSS lookups will stop"
        error "working about 1 hour after this setup."
        error ""
        error "The OIDC client '${CLIENT_ID:-pam-access}' must grant offline access:"
        error "  - set oidcRPMetaDataOptionsAllowOffline = 1 on that client in LLNG"
        error "  - ensure 'offline_access' is an allowed scope"
        error "Then delete $OB_TOKEN and re-run this setup."
        return 1
    fi
    return 0
}

# Enroll server with LLNG. Sets ENROLL_RESULT and returns 0 on success,
# 1 on failure. Callers must inspect the return code to decide whether to
# proceed with SSH/PAM lockdown.
enroll_server() {
    step "Enrolling server with LLNG..."

    if [ -n "$SERVER_TOKEN" ]; then
        # Token provided directly
        if [ "$DRY_RUN" = "true" ]; then
            info "[DRY-RUN] Would save provided server token"
            ENROLL_RESULT="dry-run"
            return 0
        fi

        echo "$SERVER_TOKEN" > "$OB_TOKEN"
        chmod 600 "$OB_TOKEN"
        info "Server token saved"
        ENROLL_RESULT="token-provided"
        return 0
    fi

    # Reuse an existing token instead of re-enrolling. A prior ob-enroll run
    # (e.g. the installer's separate enrollment step, or a previous setup)
    # may already have written the canonical token file. Re-running the
    # device-authorization flow would force a second browser approval and,
    # in --non-interactive mode, fail outright ("requires --token-file").
    # If the token file exists and is non-empty, adopt it. Delete it first
    # if you deliberately want to re-enroll.
    if [ -s "$OB_TOKEN" ]; then
        info "Existing server token found at $OB_TOKEN — reusing it (no re-enrollment)."
        require_refresh_token || { ENROLL_RESULT="failed"; return 1; }
        ENROLL_RESULT="reused"
        return 0
    fi

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would run ob-enroll"
        ENROLL_RESULT="dry-run"
        return 0
    fi

    if [ ! -x /usr/sbin/ob-enroll ]; then
        error "Enrollment helper /usr/sbin/ob-enroll not found or not executable."
        error "Install the open-bastion package or provide a token via --token-file."
        ENROLL_RESULT="failed"
        return 1
    fi

    if [ "$NON_INTERACTIVE" = "true" ]; then
        error "Cannot enroll in non-interactive mode without --token-file"
        ENROLL_RESULT="failed"
        return 1
    fi

    local enroll_opts=("-p" "$PORTAL_URL" "-g" "$SERVER_GROUP")
    if [ "$VERIFY_SSL" = "false" ]; then
        enroll_opts+=("-k")
    fi
    if [ -n "$CLIENT_ID" ]; then
        enroll_opts+=("-c" "$CLIENT_ID")
    fi

    # Pass the secret via env var (not CLI) to keep it out of /proc/<pid>/cmdline.
    # ob-enroll honours OB_CLIENT_SECRET with highest priority (see ob-enroll).
    if [ -n "$CLIENT_SECRET" ]; then
        if OB_CLIENT_SECRET="$CLIENT_SECRET" /usr/sbin/ob-enroll "${enroll_opts[@]}"; then
            require_refresh_token || { ENROLL_RESULT="failed"; return 1; }
            ENROLL_RESULT="success"
            return 0
        fi
    else
        if /usr/sbin/ob-enroll "${enroll_opts[@]}"; then
            require_refresh_token || { ENROLL_RESULT="failed"; return 1; }
            ENROLL_RESULT="success"
            return 0
        fi
    fi

    ENROLL_RESULT="failed"
    return 1
}

# Prompt for required settings (SERVER_GROUP and CLIENT_ID) before any
# system change. No silent defaults: misconfiguring either makes the bastion
# unusable, and the user should see exactly what is going to LLNG. In
# non-interactive mode (-y), missing values are fatal — the caller must
# pass them explicitly via -g / -c.
prompt_required_settings() {
    if [ -z "$SERVER_GROUP" ]; then
        if [ "$NON_INTERACTIVE" = "true" ]; then
            error "Missing --server-group (required in non-interactive mode)."
            exit 1
        fi
        printf "Server group (must match a group defined in LLNG): " >&2
        IFS= read -r SERVER_GROUP
        if [ -z "$SERVER_GROUP" ]; then
            error "Server group cannot be empty."
            exit 1
        fi
    fi

    if [ -z "$CLIENT_ID" ]; then
        if [ "$NON_INTERACTIVE" = "true" ]; then
            error "Missing --client-id (required in non-interactive mode)."
            exit 1
        fi
        local input
        printf "OIDC client_id [pam-access]: " >&2
        IFS= read -r input
        CLIENT_ID="${input:-pam-access}"
    fi
}

# Interactive prompt that asks the user for client_id and client_secret
# when an enrollment attempt failed (typically with invalid_client). Returns 0
# if new values were supplied, 1 if the user declined (or non-interactive).
prompt_for_client_credentials() {
    if [ "$NON_INTERACTIVE" = "true" ]; then
        return 1
    fi

    echo ""
    info "The LLNG portal seems to require a confidential client."
    info "Current: client_id='${CLIENT_ID:-pam-access (default)}', client_secret=$([ -n "$CLIENT_SECRET" ] && echo 'set' || echo 'empty')"
    echo ""
    if ! confirm "Provide/update client credentials and retry?"; then
        return 1
    fi

    local new_id new_secret
    printf "Client ID [%s]: " "${CLIENT_ID:-pam-access}" >&2
    IFS= read -r new_id
    if [ -n "$new_id" ]; then
        CLIENT_ID="$new_id"
    fi

    printf "Client secret (input hidden, empty = keep current): " >&2
    IFS= read -rs new_secret
    echo "" >&2
    if [ -n "$new_secret" ]; then
        CLIENT_SECRET="$new_secret"
    fi

    if [ -z "$CLIENT_SECRET" ]; then
        warn "No client_secret provided — retry will likely fail again."
    fi
    return 0
}

# Restart SSH service
restart_sshd() {
    step "Restarting SSH service..."

    if [ "$DRY_RUN" = "true" ]; then
        info "[DRY-RUN] Would restart sshd"
        return 0
    fi

    if systemctl is-active --quiet sshd 2>/dev/null; then
        systemctl restart sshd
        info "Restarted sshd.service"
    elif systemctl is-active --quiet ssh 2>/dev/null; then
        systemctl restart ssh
        info "Restarted ssh.service"
    else
        warn "Could not restart SSH service automatically"
        warn "Please restart it manually: systemctl restart sshd"
    fi
}

# Print summary
print_summary() {
    echo ""
    if [ "$ENROLL_RESULT" = "failed" ]; then
        echo "┌─────────────────────────────────────────────────────────┐"
        echo "│        Bastion Configuration INCOMPLETE                  │"
        echo "└─────────────────────────────────────────────────────────┘"
    else
        echo "┌─────────────────────────────────────────────────────────┐"
        echo "│           Bastion Configuration Complete                 │"
        echo "└─────────────────────────────────────────────────────────┘"
    fi
    echo ""
    echo "Configuration:"
    echo "  Portal URL:    $PORTAL_URL"
    echo "  Server Group:  $SERVER_GROUP"
    echo "  CA Key:        $SSH_CA_FILE"
    echo ""
    echo "Features enabled:"
    echo "  ✓ SSH certificate authentication"
    if [ "$DISABLE_SESSION_RECORDER" = "true" ]; then
        echo "  ✗ Session recording disabled (--disable-session-recorder)"
    else
        echo "  ✓ Session recording (ForceCommand)"
    fi
    echo "  ✓ LLNG authorization"
    echo "  ✓ Password authentication disabled"
    case "$ENROLL_RESULT" in
        success)
            echo "  ✓ Server enrolled with LLNG (token stored)"
            ;;
        token-provided)
            echo "  ✓ Server token installed (provided via --token-file)"
            ;;
        reused)
            echo "  ✓ Existing server token reused (no re-enrollment)"
            ;;
        dry-run)
            echo "  ✓ Server enrollment (dry-run — nothing actually saved)"
            ;;
        failed)
            echo "  ✗ Server enrollment FAILED — see [ERROR] above"
            echo "    The bastion will REJECT all logins until you run:"
            echo "      ob-enroll -p $PORTAL_URL -g $SERVER_GROUP"
            ;;
        *)
            echo "  ? Server enrollment status unknown ($ENROLL_RESULT)"
            ;;
    esac
    case "$HARDENING_RESULT" in
        applied)
            echo "  ✓ Session containment (logind KillUserProcesses, nproc cap, at/cron allowlists)"
            ;;
        partial)
            echo "  ⚠ Session containment partially applied — see [WARN] lines above"
            ;;
        dry-run)
            echo "  ✓ Session containment (dry-run — nothing actually written)"
            ;;
        declined)
            echo "  ✗ Session containment hardening (declined at confirm prompt)"
            ;;
        failed)
            echo "  ✗ Session containment hardening (failed — see [ERROR] lines above)"
            ;;
        *)
            echo "  ✗ Session containment hardening (not applied — use --enable-hardening to opt in)"
            ;;
    esac
    if [ "$MAX_SECURITY" = "true" ]; then
        echo "  ✓ Maximum Security Mode E"
        echo "    - SSH: SSO-signed certificates only"
        echo "    - sudo: LLNG temporary token required"
        echo "    - KRL: mandatory, refreshed every ${KRL_REFRESH_INTERVAL} min"
    fi
    if [ "$ENABLE_AUDIT_TRACE" = "true" ]; then
        echo "  ✓ Audit trace: applied (auditd rules + daily rotation)"
    else
        echo "  ✗ Audit trace: not applied (opt-in: --enable-audit-trace)"
    fi
    echo ""
    echo "Backup location: $BACKUP_DIR"
    echo ""
    if [ "$ENROLL_RESULT" = "failed" ]; then
        echo "ACTION REQUIRED — the bastion is NOT operational:"
        echo "  1. KEEP your current shell open (you may be locked out otherwise)."
        echo "  2. Fix portal connectivity and run:"
        echo "       ob-enroll -p $PORTAL_URL -g $SERVER_GROUP"
        echo "  3. Or roll back manually using files in $BACKUP_DIR."
        echo ""
    else
        echo "Next steps:"
        echo "  1. Verify SSH connectivity from another terminal"
        echo "  2. Test certificate authentication with ob-ssh-cert"
        echo "  3. Check session recordings in /var/lib/open-bastion/sessions/"
        echo ""
    fi
}

# Usage
usage() {
    cat << EOF
Usage: $PROG_NAME --portal URL [OPTIONS]

Configure a server as an SSH bastion with LemonLDAP::NG integration.

Required:
  -p, --portal URL        LLNG portal URL

Options:
  -g, --server-group NAME Server group name (must match a group defined in
                          LLNG). Prompted interactively if omitted; required
                          when --yes is used.
  -t, --token-file FILE   Read server token from file (use - for stdin)
  -c, --client-id ID      OIDC client_id for enrollment. Prompted interactively
                          if omitted (suggested: pam-access); required when
                          --yes is used.
  -S, --client-secret-file FILE
                          Read OIDC client_secret from file (use - for stdin).
                          Alternative: set OB_CLIENT_SECRET env var.
                          Required when the LLNG client is a confidential client.
  -y, --yes               Non-interactive mode. Requires --token-file unless a
                          server token already exists at the canonical path
                          ($OB_TOKEN), in which case it is reused.
  -k, --insecure          Skip SSL certificate verification
  --max-security          Enable Mode E (SSO certificates only, sudo via LLNG token, KRL)
  --enable-hardening      Apply system-wide containment hardening (logind KillUserProcesses,
                          mask atd, at/cron allow-lists, nproc limit). OFF by default —
                          modifies system-wide behaviour, opt in only on dedicated bastion hosts.
  --enable-audit-trace    Enable primary audit trace via auditd (OFF by default).
                          Installs audit rules (rules.d/open-bastion.rules)
                          and a daily rotation cron, then restarts auditd.
                          /etc/audit/auditd.conf is NOT modified; tune
                          retention manually (see doc/audit.md).
                          Requires auditd package (apt install auditd /
                          dnf install audit).
  --disable-session-recorder  Do NOT configure the session recorder and do not
                          force it via sshd ForceCommand. Session recording
                          is ON by default; this opts out (weakens the audit
                          guarantee — use only when recording is handled
                          elsewhere).
  -n, --dry-run           Show what would be done without making changes
  -h, --help              Show this help
  -V, --version           Show version

Example:
  $PROG_NAME --portal https://auth.example.com --server-group bastion

What this script does:
  1. Downloads SSH CA public key from LLNG
  2. Configures sshd for certificate authentication
  3. Enables session recording via ForceCommand (unless --disable-session-recorder)
  4. Configures PAM for LLNG authorization
  5. Enrolls the server with LLNG (Device Authorization)
  6. Restarts SSH service
  7. Applies session containment hardening (logind KillUserProcesses,
     nproc cap, at/cron allowlists, mask atd) ONLY if --enable-hardening
     is passed. Hardening is OFF by default.

EOF
    exit 0
}

# Parse arguments
parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -p|--portal)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    error "Option $1 requires an argument"
                    exit 1
                fi
                PORTAL_URL="$2"
                shift 2
                ;;
            -g|--server-group)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    error "Option $1 requires an argument"
                    exit 1
                fi
                SERVER_GROUP="$2"
                shift 2
                ;;
            -t|--token-file)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    error "Option $1 requires an argument"
                    exit 1
                fi
                if [ "$2" = "-" ]; then
                    SERVER_TOKEN=$(cat)
                elif [ -f "$2" ]; then
                    SERVER_TOKEN=$(cat "$2")
                else
                    error "Token file not found: $2"
                    exit 1
                fi
                shift 2
                ;;
            -c|--client-id)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    error "Option $1 requires an argument"
                    exit 1
                fi
                CLIENT_ID="$2"
                shift 2
                ;;
            -S|--client-secret-file)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    error "Option $1 requires an argument"
                    exit 1
                fi
                if [ "$2" = "-" ]; then
                    CLIENT_SECRET=$(cat)
                elif [ -f "$2" ]; then
                    CLIENT_SECRET=$(cat "$2")
                else
                    error "Client secret file not found: $2"
                    exit 1
                fi
                shift 2
                ;;
            -y|--yes)
                NON_INTERACTIVE=true
                shift
                ;;
            -k|--insecure)
                VERIFY_SSL=false
                shift
                ;;
            --max-security)
                MAX_SECURITY=true
                shift
                ;;
            --enable-hardening)
                ENABLE_HARDENING=true
                shift
                ;;
            --enable-audit-trace)
                ENABLE_AUDIT_TRACE=true
                shift
                ;;
            --disable-session-recorder)
                DISABLE_SESSION_RECORDER=true
                shift
                ;;
            -n|--dry-run)
                DRY_RUN=true
                shift
                ;;
            -h|--help)
                usage
                ;;
            -V|--version)
                echo "$PROG_NAME version $VERSION"
                exit 0
                ;;
            *)
                error "Unknown option: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
        esac
    done
}

# Main
main() {
    parse_args "$@"

    # Validate required parameters
    if [ -z "$PORTAL_URL" ]; then
        error "Portal URL is required (-p/--portal)"
        exit 1
    fi

    # Remove trailing slash
    PORTAL_URL="${PORTAL_URL%/}"

    # Pick up client_secret from env if not provided via --client-secret-file.
    # Storing it in OB_CLIENT_SECRET keeps it out of /proc/<pid>/cmdline.
    if [ -z "$CLIENT_SECRET" ] && [ -n "${OB_CLIENT_SECRET:-}" ]; then
        CLIENT_SECRET="$OB_CLIENT_SECRET"
    fi

    # Security: warn if not using HTTPS (credentials sent in clear)
    if [[ "$PORTAL_URL" != https://* ]] && [[ "$VERIFY_SSL" != "false" ]]; then
        warn "PORTAL_URL does not use HTTPS - credentials will be sent in clear text"
    fi

    # Check root
    check_root

    # Check dependencies
    for cmd in curl sshd; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            error "Required command not found: $cmd"
            exit 1
        fi
    done

    # Ask for server_group and client_id BEFORE printing the banner so the
    # final summary the user confirms reflects the values that will be used.
    prompt_required_settings

    echo ""
    echo "┌─────────────────────────────────────────────────────────┐"
    echo "│        LemonLDAP::NG Bastion Setup                       │"
    echo "└─────────────────────────────────────────────────────────┘"
    echo ""
    echo "This script will configure this server as an SSH bastion."
    echo ""
    echo "Portal URL:    $PORTAL_URL"
    echo "Server Group:  $SERVER_GROUP"
    echo "Client ID:     $CLIENT_ID"
    if [ "$MAX_SECURITY" = "true" ]; then
        echo "Max Security: true (Mode E)"
    fi
    echo ""

    if [ "$DRY_RUN" = "true" ]; then
        warn "DRY-RUN MODE - No changes will be made"
        echo ""
    fi

    if ! confirm "Continue with bastion setup?"; then
        info "Aborted"
        exit 0
    fi

    echo ""

    # ── Phase 1: inert preparation (no SSH/PAM lockdown yet) ──
    # These steps download/create files that are NOT referenced by sshd or PAM
    # until phase 3 runs. If anything fails here, or if enrollment fails in
    # phase 2, the system is still usable: rollback_on_failure() restores
    # backups / removes new files and exits.
    download_ca_key || { rollback_on_failure; exit 1; }
    install_principals_helper || { rollback_on_failure; exit 1; }
    configure_pam_openbastion || { rollback_on_failure; exit 1; }
    if [ "$DISABLE_SESSION_RECORDER" = "true" ]; then
        info "Session recorder disabled (--disable-session-recorder)"
    else
        configure_session_recorder || { rollback_on_failure; exit 1; }
    fi

    # ── Phase 2: portal connectivity + enrollment ──
    # Must succeed before we lock down SSH/PAM, otherwise the bastion would
    # be unreachable (PasswordAuthentication=no + no certs because no token).
    if ! preflight_check_portal; then
        rollback_on_failure
        exit 1
    fi

    # Retry loop: on enrollment failure (typically invalid_client), offer
    # the user a chance to provide/update client_id and client_secret and
    # retry — without restarting the whole setup.
    local max_attempts=3
    local attempt=1
    while ! enroll_server; do
        error ""
        error "Server enrollment FAILED (attempt $attempt/$max_attempts)."

        if [ $attempt -ge $max_attempts ]; then
            error "Maximum enrollment attempts reached."
            break
        fi

        if ! prompt_for_client_credentials; then
            # User declined / non-interactive — fall through to fatal handling.
            break
        fi

        attempt=$((attempt + 1))
        info "Retrying enrollment..."
    done

    if [ "$ENROLL_RESULT" != "success" ] && [ "$ENROLL_RESULT" != "token-provided" ] && [ "$ENROLL_RESULT" != "reused" ] && [ "$ENROLL_RESULT" != "dry-run" ]; then
        if [ "$MAX_SECURITY" = "true" ]; then
            error "Refusing to apply --max-security lockdown: without enrollment, no user"
            error "can authenticate (SSO certs cannot be issued, sudo would require"
            error "a token nobody can obtain). Aborting BEFORE any SSH/PAM changes."
            rollback_on_failure
            exit 1
        fi
        warn "PAM authorization will fail until you run:"
        warn "  ob-enroll -p $PORTAL_URL -g $SERVER_GROUP${CLIENT_ID:+ -c $CLIENT_ID}"
        warn "manually after this setup completes."
        echo ""
        if ! confirm "Continue applying SSH/PAM lockdown anyway? (DANGEROUS)"; then
            info "Aborted by user."
            rollback_on_failure
            exit 1
        fi
    else
        # Persist any client_id/client_secret entered during retry prompts so
        # future re-enrollments via ob-enroll alone keep working.
        refresh_openbastion_conf
    fi

    # ── Phase 3: SSH / PAM lockdown ──
    # From this point on, a failure may require restoring files from
    # $BACKUP_DIR by hand.
    configure_sshd || exit 1
    configure_pam_sshd || exit 1
    configure_max_security_sshd || exit 1
    configure_max_security_sudo || exit 1
    configure_nss || exit 1
    if [ "$ENABLE_HARDENING" = "true" ]; then
        setup_hardening || warn "Hardening step reported errors"
    else
        info "Session containment hardening not applied (opt-in: pass --enable-hardening to activate)"
    fi
    download_krl || warn "KRL download failed"

    # Optional primary audit trace (default OFF — modifies global system).
    if [ "$ENABLE_AUDIT_TRACE" = "true" ]; then
        setup_audit_trace || warn "Audit trace setup failed (see errors above)"
    else
        info "Audit trace not applied (opt-in: pass --enable-audit-trace)"
    fi

    if [ "$DRY_RUN" = "false" ]; then
        restart_sshd || warn "Failed to restart SSH"
    fi

    print_summary
}

main "$@"
