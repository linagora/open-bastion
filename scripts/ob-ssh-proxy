#!/bin/bash
# shellcheck disable=SC2155
#
# ob-ssh-proxy - bastion-to-backend connector with LLNG certificate vouching
#
# Run on a bastion server, by a user already authenticated to the bastion, to
# reach a backend WITHOUT any SSH key of their own on the bastion and without
# agent forwarding. The bastion mints a short-lived, LLNG-signed certificate
# for this user and re-originates the SSH connection to the backend with it.
#
# Usage (on the bastion):
#     ob-ssh-proxy [user@]backend [port]
#
# Flow:
#   1. Reads the per-session bastion voucher from $LLNG_BASTION_VOUCHER (set by
#      pam_openbastion at bastion login; it proves THIS user connected to THIS
#      bastion).
#   2. Generates an ephemeral keypair in tmpfs (the private key never leaves the
#      bastion and is wiped on exit).
#   3. POSTs the ephemeral public key + voucher to LLNG /pam/bastion-cert and
#      receives a short-lived user certificate (principal = user, pinned to the
#      bastion IP, bastion_id in the key-id).
#   4. Connects to the backend with `ssh -i <ephkey> -o CertificateFile=<cert>`.
#
# This replaces the old (broken) JWT-over-SendEnv transport: SendEnv/AcceptEnv
# never populate the PAM environment pam_getenv reads, so the backend rejected
# every session. See doc/design/bastion-cert-vouching.md.
#
# Copyright (C) 2025 Linagora
# Author: Xavier Guimard <xguimard@linagora.com>
# License: AGPL-3.0

set -euo pipefail

VERSION="0.2.3"
PROG_NAME=$(basename "$0")

# Configuration (can be overridden via /etc/open-bastion/ssh-proxy.conf)
PORTAL_URL=""
SERVER_TOKEN_FILE="/etc/open-bastion/token"
TARGET_GROUP="default"
TIMEOUT=10
VERIFY_SSL=true
SSH_OPTIONS_ARRAY=()
DEBUG=false

# Per-session voucher proving this user connected to this bastion. Set by
# pam_openbastion (pam_putenv) at bastion login and inherited by this session
# on the SAME host — unlike the old SendEnv JWT, this transport actually works.
VOUCHER="${LLNG_BASTION_VOUCHER:-}"

# Configuration file (must be owned by root and not group/world-writable)
CONFIG_FILE="/etc/open-bastion/ssh-proxy.conf"

# Load configuration securely
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # Security: verify config file permissions before sourcing
        local file_stat
        file_stat=$(stat -c '%u:%a' "$CONFIG_FILE" 2>/dev/null)
        if [ -z "$file_stat" ]; then
            error "Unable to check permissions for config file: $CONFIG_FILE"
            exit 1
        fi

        local owner="${file_stat%%:*}"
        local perms="${file_stat##*:}"

        # Must be owned by root (uid 0)
        if [ "$owner" != "0" ]; then
            error "Insecure config file ownership (must be root): $CONFIG_FILE"
            exit 1
        fi

        # Check for group-writable (x2x) or world-writable (xx2)
        if [ $((perms % 100 / 10 & 2)) -ne 0 ] || [ $((perms % 10 & 2)) -ne 0 ]; then
            error "Insecure config file permissions (group/world-writable): $CONFIG_FILE"
            exit 1
        fi

        # Parse config file safely (no sourcing to prevent code injection)
        local key value
        while IFS='=' read -r key value || [ -n "$key" ]; do
            # Skip comments and empty lines
            key="${key%%#*}"
            key="${key// /}"
            [ -z "$key" ] && continue
            # Remove surrounding quotes from value
            value="${value#"${value%%[![:space:]]*}"}"
            value="${value%"${value##*[![:space:]]}"}"
            value="${value#\"}" ; value="${value%\"}"
            value="${value#\'}" ; value="${value%\'}"
            case "$key" in
                PORTAL_URL)          PORTAL_URL="$value" ;;
                SERVER_TOKEN_FILE)   SERVER_TOKEN_FILE="$value" ;;
                # SERVER_GROUP accepted-but-ignored (back-compat): the bastion's
                # group is resolved server-side from its enrolled token.
                SERVER_GROUP)        : ;;
                TARGET_GROUP)        TARGET_GROUP="$value" ;;
                TIMEOUT)             TIMEOUT="$value" ;;
                VERIFY_SSL)          VERIFY_SSL="$value" ;;
                DEBUG)               DEBUG="$value" ;;
                SSH_OPTIONS)
                    read -r -a SSH_OPTIONS_ARRAY <<<"$value"
                    ;;
            esac
        done < "$CONFIG_FILE"
    fi
}

# Debug logging
debug() {
    if [ "$DEBUG" = "true" ]; then
        echo "[DEBUG] $*" >&2
    fi
}

# Warning logging
warn() {
    echo "[WARN] $*" >&2
}

# Error logging
error() {
    echo "[ERROR] $*" >&2
}

# Build curl options array
# Returns options via the global CURL_OPTS array (safer than mapfile)
build_curl_opts() {
    # --fail-with-body (not -f): on a non-2xx response curl still writes the
    # JSON error body to stdout AND returns non-zero, so the caller can detect
    # structured reasons like {"reason":"voucher_expired"} instead of getting an
    # empty body. (-f would discard the body and hide the reason.)
    CURL_OPTS=("-s" "--fail-with-body" "--connect-timeout" "$TIMEOUT")
    if [ "$VERIFY_SSL" = "false" ]; then
        CURL_OPTS+=("-k")
    fi
}

# Get server token
get_server_token() {
    if [ ! -f "$SERVER_TOKEN_FILE" ]; then
        error "Server token file not found: $SERVER_TOKEN_FILE"
        exit 1
    fi

    # Support both JSON format (from ob-enroll) and plain text
    if head -c1 "$SERVER_TOKEN_FILE" | grep -q '{'; then
        # JSON format: extract access_token
        jq -r '.access_token // empty' "$SERVER_TOKEN_FILE" 2>/dev/null || cat "$SERVER_TOKEN_FILE"
    else
        # Plain text format
        cat "$SERVER_TOKEN_FILE"
    fi
}

# Validate hostname to prevent SSH option injection
# Only allows: alphanumeric, dots, hyphens, colons (IPv6), brackets
validate_hostname() {
    local host="$1"
    # NB: in an ERE bracket expression a literal ']' must come FIRST (and '-'
    # last); '\]' does NOT escape it — it closes the set and breaks the regex.
    if [[ ! "$host" =~ ^[][a-zA-Z0-9.:_-]+$ ]]; then
        error "Invalid hostname: $host"
        exit 1
    fi
    # Reject hostnames starting with '-' (SSH option injection)
    if [[ "$host" == -* ]]; then
        error "Invalid hostname (starts with dash): $host"
        exit 1
    fi
}

# Request a short-lived bastion certificate from LLNG.
# Args: <user> <target_host> <ephemeral_public_key>
# Prints the signed certificate on stdout; returns non-zero on failure (with a
# clear message on stderr).
request_bastion_cert() {
    local user="$1"
    local target_host="$2"
    local pubkey="$3"

    if [ -z "$VOUCHER" ]; then
        error "No bastion voucher found (LLNG_BASTION_VOUCHER is unset)."
        error "This session was not vouched by the bastion PAM module (or it"
        error "predates the cert-vouching feature). Reconnect to the bastion."
        return 1
    fi

    debug "Requesting bastion cert for user $user to host $target_host"

    local response
    if [ -r "$SERVER_TOKEN_FILE" ]; then
        # Privileged path (root, or a relaxed lab setup): call LLNG directly.
        local server_token
        server_token=$(get_server_token)
        if [ -z "$server_token" ]; then
            error "Failed to read server token"
            return 1
        fi

        build_curl_opts

        # Build JSON payload safely with jq to avoid injection
        local json_payload
        json_payload=$(jq -n \
            --arg user "$user" \
            --arg target_host "$target_host" \
            --arg target_group "$TARGET_GROUP" \
            --arg public_key "$pubkey" \
            --arg voucher "$VOUCHER" \
            '{user: $user, target_host: $target_host, target_group: $target_group, public_key: $public_key, voucher: $voucher}')

        # 2>/dev/null (not 2>&1): keep curl's stderr OUT of $response so it stays
        # valid JSON for the parsing below. With --fail-with-body the JSON error
        # body is captured even on non-2xx, so we do NOT early-return on a
        # non-zero rc — the shared parser below extracts .reason/.error (e.g.
        # voucher_expired) and prints the right message. Only a truly empty
        # response (network failure) is a hard error here.
        response=$(curl "${CURL_OPTS[@]}" \
            -X POST \
            -H "Authorization: Bearer $server_token" \
            -H "Content-Type: application/json" \
            -d "$json_payload" \
            "${PORTAL_URL}/pam/bastion-cert" 2>/dev/null) || true
        if [ -z "$response" ]; then
            error "Failed to request bastion certificate (no response from ${PORTAL_URL}/pam/bastion-cert)"
            return 1
        fi
    else
        # Normal user path: the server token is root-only BY DESIGN (a user
        # reading their own voucher must gain nothing). Delegate the single
        # privileged call to ob-bastion-cert-helper through the narrow
        # NOPASSWD sudoers rule installed by ob-bastion-setup. The helper
        # always mints for the INVOKING user, whatever we send it.
        debug "Server token not readable; delegating to ob-bastion-cert-helper"
        local rc=0
        response=$(printf '%s\n%s\n' "$VOUCHER" "$pubkey" \
            | sudo -n /usr/sbin/ob-bastion-cert-helper "$target_host" "$TARGET_GROUP") || rc=$?
        if [ -z "$response" ]; then
            error "Failed to request bastion certificate via ob-bastion-cert-helper (rc=$rc)."
            error "Is the sudoers rule installed? (re-run ob-bastion-setup on this bastion)"
            return 1
        fi
    fi

    local cert
    cert=$(echo "$response" | jq -r '.certificate // empty' 2>/dev/null)
    if [ -z "$cert" ]; then
        local reason err_msg
        reason=$(echo "$response" | jq -r '.reason // empty' 2>/dev/null)
        err_msg=$(echo "$response" | jq -r '.error // .message // empty' 2>/dev/null)
        if [ "$reason" = "voucher_expired" ]; then
            error "Your bastion authorization has expired."
            error "Reconnect to the bastion to refresh it, then retry."
        elif [ -n "$err_msg" ]; then
            error "LLNG refused to issue a certificate: $err_msg${reason:+ ($reason)}"
        else
            error "Invalid response from LLNG: $response"
        fi
        return 1
    fi

    printf '%s\n' "$cert"
}

# Mint an ephemeral cert and re-originate the SSH connection to the backend.
# Args: <target_host> <target_user> [target_port]
connect_via_cert() {
    local target_host="$1"
    local target_user="$2"
    local target_port="${3:-22}"

    validate_hostname "$target_host"

    # Ephemeral keypair in tmpfs; private key never leaves the bastion.
    local tmpd
    tmpd=$(mktemp -d "${XDG_RUNTIME_DIR:-/dev/shm}/ob-hop.XXXXXX") || {
        error "Failed to create ephemeral key directory"
        exit 1
    }
    chmod 700 "$tmpd"
    # shellcheck disable=SC2064
    trap "rm -rf '$tmpd'" EXIT INT TERM

    ssh-keygen -t ed25519 -N '' -q -f "$tmpd/id" -C "ob-ephemeral" || {
        error "Failed to generate ephemeral keypair"
        exit 1
    }
    local pubkey
    pubkey=$(cat "$tmpd/id.pub")

    local cert
    cert=$(request_bastion_cert "$target_user" "$target_host" "$pubkey") || exit 1
    printf '%s\n' "$cert" > "$tmpd/id-cert.pub"

    debug "Got ephemeral cert, connecting to ${target_user}@${target_host}:${target_port}"

    # Re-originate: the BASTION authenticates to the backend with the cert.
    local rc=0
    ssh -i "$tmpd/id" \
        -o CertificateFile="$tmpd/id-cert.pub" \
        -o IdentitiesOnly=yes \
        -o StrictHostKeyChecking=accept-new \
        -p "$target_port" \
        "${SSH_OPTIONS_ARRAY[@]}" \
        -l "$target_user" \
        -- "$target_host" || rc=$?

    rm -rf "$tmpd"
    trap - EXIT INT TERM
    exit $rc
}

# Parse a "[user@]host" spec into globals SPEC_USER / SPEC_HOST.
parse_target_spec() {
    local spec="$1"
    local default_user="$2"
    if [[ "$spec" == *@* ]]; then
        SPEC_USER="${spec%%@*}"
        SPEC_HOST="${spec#*@}"
    else
        SPEC_USER="$default_user"
        SPEC_HOST="$spec"
    fi
}

# Direct mode: user runs `ob-ssh-proxy [user@]backend [port]` on the bastion.
direct_mode() {
    local spec="$1"
    local port="${2:-22}"
    local user="${USER:-$(whoami)}"
    parse_target_spec "$spec" "$user"
    connect_via_cert "$SPEC_HOST" "$SPEC_USER" "$port"
}

# ForceCommand mode: the original command is in SSH_ORIGINAL_COMMAND
# (e.g. "ssh backend" or "ssh user@backend").
force_command_mode() {
    local user="${USER:-$(whoami)}"
    local ssh_cmd="${SSH_ORIGINAL_COMMAND:-}"

    if [ -z "$ssh_cmd" ]; then
        error "No SSH_ORIGINAL_COMMAND set"
        exit 1
    fi

    debug "Original command: $ssh_cmd"

    # Walk the tokens the way ssh(1) parses them: skip flags and the argument of
    # any option that takes one, so `ssh -p 2222 backend` or
    # `ssh -o Foo=bar user@backend` resolve to the host — not the option or its
    # value. -p / -l additionally seed the target port / user.
    local -a toks=()
    read -r -a toks <<<"$ssh_cmd"
    [ "${toks[0]:-}" = "ssh" ] && toks=("${toks[@]:1}")

    local target="" port=22 i=0 n=${#toks[@]}
    while [ "$i" -lt "$n" ]; do
        local t="${toks[$i]}"
        case "$t" in
            --)  i=$((i + 1)); target="${toks[$i]:-}"; break ;;
            -p)  port="${toks[$((i + 1))]:-22}";   i=$((i + 2)); continue ;;
            -l)  user="${toks[$((i + 1))]:-$user}"; i=$((i + 2)); continue ;;
            # Options that consume the NEXT token as their argument.
            -b|-c|-D|-E|-e|-F|-I|-i|-J|-L|-m|-O|-o|-Q|-R|-S|-W|-w)
                 i=$((i + 2)); continue ;;
            -p*) port="${t#-p}"; i=$((i + 1)); continue ;;
            -l*) user="${t#-l}"; i=$((i + 1)); continue ;;
            -*)  i=$((i + 1)); continue ;;   # attached-value or bare flag(s)
            *)   target="$t"; break ;;
        esac
    done

    if [ -z "$target" ]; then
        error "Could not parse target host from command: $ssh_cmd"
        exit 1
    fi

    parse_target_spec "$target" "$user"
    connect_via_cert "$SPEC_HOST" "$SPEC_USER" "$port"
}

# Interactive mode: prompt for a target.
interactive_mode() {
    local user="${USER:-$(whoami)}"

    echo "Welcome to the LLNG bastion server"
    echo ""
    echo "Usage: ob-ssh-proxy [user@]<backend-hostname> [port]"
    echo ""
    echo -n "Enter target host ([user@]host): "
    read -r spec

    if [ -z "$spec" ]; then
        error "No target specified"
        exit 1
    fi

    parse_target_spec "$spec" "$user"
    connect_via_cert "$SPEC_HOST" "$SPEC_USER" 22
}

# Show usage
usage() {
    cat <<EOF
Usage: $PROG_NAME [OPTIONS] [user@]backend [port]

Bastion-to-backend connector with LLNG certificate vouching. Run on a bastion
by a user already authenticated to it; the bastion mints a short-lived,
LLNG-signed certificate and re-originates the SSH connection to the backend.
No SSH key of your own on the bastion and no agent forwarding are needed.

Modes:
  Direct mode:        $PROG_NAME [user@]backend [port]
  ForceCommand mode:  $PROG_NAME            (reads SSH_ORIGINAL_COMMAND)
  Interactive mode:   $PROG_NAME            (prompts for target)

Options:
  -c, --config FILE   Use alternate config file (default: $CONFIG_FILE)
  -d, --debug         Enable debug output
  -h, --help          Show this help
  -V, --version       Show version

Configuration ($CONFIG_FILE):
    PORTAL_URL="https://auth.example.com"
    SERVER_TOKEN_FILE="/etc/open-bastion/token"
    SERVER_GROUP="bastion"
    TARGET_GROUP="default"
    TIMEOUT=10
    VERIFY_SSL=true
    DEBUG=false

The backend's sshd must trust the LLNG SSH CA (TrustedUserCAKeys). No AcceptEnv
is required (the old LLNG_BASTION_JWT / SendEnv transport is gone).
EOF
}

# Parse arguments
parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -c|--config)
                CONFIG_FILE="$2"
                shift 2
                ;;
            -d|--debug)
                DEBUG=true
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -V|--version)
                echo "$PROG_NAME version $VERSION"
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    # Remaining arguments: [user@]host [port]
    TARGET_SPEC="${1:-}"
    TARGET_PORT="${2:-22}"
}

# Main
main() {
    parse_args "$@"
    load_config

    # Validate required configuration
    if [ -z "$PORTAL_URL" ]; then
        error "PORTAL_URL not configured. Set it in $CONFIG_FILE"
        exit 1
    fi

    # Security: warn if not using HTTPS (credentials sent in clear)
    if [[ "$PORTAL_URL" != https://* ]] && [[ "$VERIFY_SSL" != "false" ]]; then
        warn "PORTAL_URL does not use HTTPS - credentials will be sent in clear text"
    fi

    # Determine mode
    if [ -n "$TARGET_SPEC" ]; then
        debug "Direct mode: $TARGET_SPEC:$TARGET_PORT"
        direct_mode "$TARGET_SPEC" "$TARGET_PORT"
    elif [ -n "${SSH_ORIGINAL_COMMAND:-}" ]; then
        debug "ForceCommand mode"
        force_command_mode
    else
        debug "Interactive mode"
        interactive_mode
    fi
}

main "$@"
