#!/bin/bash
#
# ob-bastion-cert-helper - privileged half of ob-ssh-proxy's certificate request
#
# ob-ssh-proxy runs as the logged-in bastion user, but /pam/bastion-cert must be
# authenticated with the bastion's server token, which is root-only BY DESIGN
# (a user reading their own voucher must gain nothing). This helper is the
# bridge: it is invoked through a `sudo -n` rule installed by ob-bastion-setup
# and performs exactly one privileged operation — POST the invoking user's
# voucher + ephemeral public key to LLNG /pam/bastion-cert with the server
# token as Bearer — then prints the raw LLNG JSON response on stdout.
#
# Security properties:
#   * The certificate is always requested for the SUDO INVOKER ($SUDO_USER):
#     a caller cannot mint a certificate for any other user, regardless of the
#     voucher it supplies (LLNG additionally checks the voucher against the
#     same (bastion_id, user) pair, so a stolen voucher is doubly useless).
#   * The voucher and public key are read from stdin, never from argv, so they
#     do not transit /proc/<pid>/cmdline.
#   * The server token never leaves this process.
#   * No setuid binary: privilege comes from a narrow sudoers entry
#     (see ob-bastion-setup configure_ssh_proxy_sudoers).
#
# Usage:  ob-bastion-cert-helper <target_host> [target_group]
# Stdin:  line 1 = voucher, line 2 = ephemeral SSH public key
# Stdout: the LLNG /pam/bastion-cert JSON response (ob-ssh-proxy parses it)
#
# Copyright (C) 2025 Linagora
# Author: Xavier Guimard <xguimard@linagora.com>
# License: AGPL-3.0

set -euo pipefail

PROG_NAME=$(basename "$0")
OB_CONFIG="/etc/open-bastion/openbastion.conf"
PROXY_CONFIG="/etc/open-bastion/ssh-proxy.conf"
SERVER_TOKEN_FILE="/var/lib/open-bastion/token"
TIMEOUT=10
VERIFY_SSL=true
PORTAL_URL=""

error() { echo "[$PROG_NAME] ERROR: $*" >&2; }

# ── Privilege & invoker checks ───────────────────────────────────────────────
if [ "$(id -u)" -ne 0 ]; then
    error "must run as root (invoked via the sudoers rule installed by ob-bastion-setup)"
    exit 1
fi

# The user the certificate is minted for is ALWAYS the sudo invoker.
CERT_USER="${SUDO_USER:-}"
if [ -z "$CERT_USER" ]; then
    # Direct root invocation (no sudo): mint for root itself. Mainly useful
    # for admin debugging; LLNG will refuse unless 'root' is an SSO user.
    CERT_USER="$(id -un)"
fi
if [[ ! "$CERT_USER" =~ ^[a-z_][a-z0-9._-]*$ ]]; then
    error "invalid invoking user name: $CERT_USER"
    exit 1
fi

# ── Arguments ────────────────────────────────────────────────────────────────
TARGET_HOST="${1:-}"
TARGET_GROUP="${2:-default}"
if [ -z "$TARGET_HOST" ]; then
    error "usage: $PROG_NAME <target_host> [target_group]  (voucher + pubkey on stdin)"
    exit 1
fi
# NB: ']' first / '-' last inside the bracket expression (ERE rules).
if [[ ! "$TARGET_HOST" =~ ^[][a-zA-Z0-9.:_-]+$ ]] || [[ "$TARGET_HOST" == -* ]]; then
    error "invalid target host: $TARGET_HOST"
    exit 1
fi
if [[ ! "$TARGET_GROUP" =~ ^[A-Za-z0-9._-]+$ ]]; then
    error "invalid target group: $TARGET_GROUP"
    exit 1
fi

# ── Stdin: voucher then public key ───────────────────────────────────────────
IFS= read -r VOUCHER || true
IFS= read -r PUBKEY || true
if [ -z "$VOUCHER" ] || [ -z "$PUBKEY" ]; then
    error "expected voucher (line 1) and SSH public key (line 2) on stdin"
    exit 1
fi
if [[ ! "$PUBKEY" =~ ^(ssh-[a-z0-9]+|ecdsa-sha2-[a-z0-9-]+)\ [A-Za-z0-9+/]+={0,2}(\ [^$'\r\n']*)?$ ]]; then
    error "invalid SSH public key format"
    exit 1
fi

# ── Configuration (root-readable) ────────────────────────────────────────────
# portal_url / verify_ssl from openbastion.conf (ini style: key = value)
read_ini() { # file key
    sed -n "s/^[[:space:]]*$2[[:space:]]*=[[:space:]]*//p" "$1" 2>/dev/null | tail -1
}
if [ -f "$OB_CONFIG" ]; then
    PORTAL_URL=$(read_ini "$OB_CONFIG" portal_url)
    v=$(read_ini "$OB_CONFIG" verify_ssl); [ -n "$v" ] && VERIFY_SSL="$v"
fi
# ssh-proxy.conf (shell style KEY="value") may override, same keys as ob-ssh-proxy
if [ -f "$PROXY_CONFIG" ]; then
    file_stat=$(stat -c '%u:%a' "$PROXY_CONFIG" 2>/dev/null)
    owner=${file_stat%%:*}; mode=${file_stat##*:}
    if [ "$owner" = "0" ] && [[ "$mode" =~ ^[0-7]?[0-7][0-5][0-5]$ ]]; then
        while IFS='=' read -r key value; do
            [[ "$key" =~ ^[[:space:]]*# ]] && continue
            key=$(echo "$key" | tr -d '[:space:]')
            value="${value%\"}"; value="${value#\"}"
            case "$key" in
                PORTAL_URL)        PORTAL_URL="$value" ;;
                SERVER_TOKEN_FILE) SERVER_TOKEN_FILE="$value" ;;
                VERIFY_SSL)        VERIFY_SSL="$value" ;;
                TIMEOUT)           TIMEOUT="$value" ;;
            esac
        done < "$PROXY_CONFIG"
    fi
fi
PORTAL_URL="${PORTAL_URL%/}"
if [ -z "$PORTAL_URL" ]; then
    error "portal_url not found in $OB_CONFIG (or PORTAL_URL in $PROXY_CONFIG)"
    exit 1
fi

# ── Server token ─────────────────────────────────────────────────────────────
if [ ! -f "$SERVER_TOKEN_FILE" ]; then
    error "server token file not found: $SERVER_TOKEN_FILE (is this host enrolled?)"
    exit 1
fi
if head -c1 "$SERVER_TOKEN_FILE" | grep -q '{'; then
    SERVER_TOKEN=$(jq -r '.access_token // empty' "$SERVER_TOKEN_FILE" 2>/dev/null)
else
    SERVER_TOKEN=$(cat "$SERVER_TOKEN_FILE")
fi
if [ -z "$SERVER_TOKEN" ]; then
    error "failed to read server token from $SERVER_TOKEN_FILE"
    exit 1
fi

# ── Request ──────────────────────────────────────────────────────────────────
CURL_OPTS=(-sS --fail-with-body --max-time "$TIMEOUT")
[ "$VERIFY_SSL" = "false" ] && CURL_OPTS+=(-k)

json_payload=$(jq -n \
    --arg user "$CERT_USER" \
    --arg target_host "$TARGET_HOST" \
    --arg target_group "$TARGET_GROUP" \
    --arg public_key "$PUBKEY" \
    --arg voucher "$VOUCHER" \
    '{user: $user, target_host: $target_host, target_group: $target_group, public_key: $public_key, voucher: $voucher}')

# --fail-with-body: non-2xx still prints the JSON error body (reason codes like
# voucher_expired) so ob-ssh-proxy can show the right message to the user.
response=$(curl "${CURL_OPTS[@]}" \
    -X POST \
    -H "Authorization: Bearer $SERVER_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$json_payload" \
    "${PORTAL_URL}/pam/bastion-cert") || rc=$?

printf '%s\n' "$response"
exit "${rc:-0}"
