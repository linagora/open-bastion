#!/bin/bash
#
# ob-session-recorder - Record SSH sessions for audit purposes
#
# This script is designed to be used as ForceCommand in sshd_config
# to record all SSH sessions passing through a bastion host.
#
# Supports recording formats:
# - script: Plain typescript (default, always available)
# - asciinema: Using asciinema tool if installed
# - ttyrec: Using ttyrec tool if installed
#
# Copyright (C) 2025 Linagora
# License: AGPL-3.0

set -euo pipefail

VERSION="0.2.3"
PROG_NAME=$(basename "$0")

# Default configuration
CONFIG_FILE="${OB_RECORDER_CONFIG:-/etc/open-bastion/session-recorder.conf}"
SESSIONS_DIR="${OB_SESSIONS_DIR:-/var/lib/open-bastion/sessions}"
FORMAT="${OB_RECORDER_FORMAT:-script}"
MAX_SESSION_DURATION="${OB_MAX_SESSION:-86400}"  # 24 hours default

# Metadata
SESSION_ID=""
# Derive username from real uid, not $USER (which is user-controllable).
SESSION_USER="$(id -un 2>/dev/null || echo unknown)"
SESSION_START=""
ORIGINAL_COMMAND="${SSH_ORIGINAL_COMMAND:-}"
CLIENT_IP="${SSH_CLIENT:+${SSH_CLIENT%% *}}"
CLIENT_IP="${CLIENT_IP:-unknown}"
TTY_NAME="${SSH_TTY:-notty}"

# Security: validate SESSION_USER to prevent path traversal attacks.
# Must contain only safe characters before it is used to construct file paths.
if [[ ! "$SESSION_USER" =~ ^[a-z_][a-z0-9_.-]*$ ]]; then
    SAFE_USER=$(printf '%q' "$SESSION_USER")
    logger -t "$PROG_NAME" -p auth.err "Invalid session user: $SAFE_USER"
    echo "Error: invalid session user" >&2
    exit 1
fi

# Process management
TIMEOUT_PID=""
RECORDING_PID=""

# Logging to syslog
log_info() {
    logger -t "$PROG_NAME" -p auth.info "$*"
}

log_warn() {
    logger -t "$PROG_NAME" -p auth.warning "$*"
}

log_err() {
    logger -t "$PROG_NAME" -p auth.err "$*"
}

# Generate unique session ID (UUID v4)
generate_session_id() {
    if command -v uuidgen >/dev/null 2>&1; then
        uuidgen
    elif [ -r /proc/sys/kernel/random/uuid ]; then
        cat /proc/sys/kernel/random/uuid
    else
        # Fallback: timestamp + random
        printf '%s-%s' "$(date +%Y%m%d%H%M%S)" "$(head -c 8 /dev/urandom | od -An -tx1 | tr -d ' \n')"
    fi
}

# Load configuration file
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        # Security: verify config file permissions before parsing
        local file_stat
        file_stat=$(stat -c '%u:%a' "$CONFIG_FILE" 2>/dev/null || stat -f '%u:%Lp' "$CONFIG_FILE" 2>/dev/null)
        if [ -n "$file_stat" ]; then
            local owner="${file_stat%%:*}"
            local perms="${file_stat##*:}"
            if [ "$owner" != "0" ]; then
                log_warn "Config file not owned by root: $CONFIG_FILE (ignoring)"
                return
            fi
            if [ $((perms % 100 / 10 & 2)) -ne 0 ] || [ $((perms % 10 & 2)) -ne 0 ]; then
                log_warn "Config file is group/world-writable: $CONFIG_FILE (ignoring)"
                return
            fi
        fi
        while IFS= read -r line; do
            # Skip comments and empty lines
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// }" ]] && continue

            # Parse key=value, handling inline comments
            if [[ "$line" =~ ^[[:space:]]*([a-z_]+)[[:space:]]*=[[:space:]]*(.+)$ ]]; then
                local key="${BASH_REMATCH[1]}"
                local value="${BASH_REMATCH[2]}"

                # Remove inline comments and trailing whitespace
                value="${value%%#*}"
                value="${value%"${value##*[![:space:]]}"}"

                # Remove surrounding quotes
                value="${value#[\"\']}"
                value="${value%[\"\']}"

                case "$key" in
                    sessions_dir) SESSIONS_DIR="$value" ;;
                    format) FORMAT="$value" ;;
                    max_duration) MAX_SESSION_DURATION="$value" ;;
                esac
            fi
        done < "$CONFIG_FILE"
    fi
}

# Build the one-line JSON metadata header sent to the recording sink. The sink
# (root) writes the actual metadata file and is the authority on user/start/end/
# status; everything here is informational only (the sink JSON-escapes it). MUST
# be a single line (no embedded newline) — ob-record-connect rejects newlines.
build_header() {
    if command -v jq >/dev/null 2>&1; then
        jq -cn \
            --arg sid "$SESSION_ID" \
            --arg fmt "$FORMAT" \
            --arg ip "$CLIENT_IP" \
            --arg tty "$TTY_NAME" \
            --arg cmd "$ORIGINAL_COMMAND" \
            --arg start "$SESSION_START" \
            '{v:1,session_id:$sid,format:$fmt,client_ip:$ip,ssh_tty:$tty,original_command:$cmd,start:$start}'
    else
        # Minimal fallback (jq is a package dependency; this is best-effort). We
        # MUST keep the header on one line, so JSON-escape backslash, quote and
        # the control chars that would otherwise break it (newline/CR/tab) in the
        # only field that can carry them, original_command.
        local c="${ORIGINAL_COMMAND//\\/\\\\}"
        c="${c//\"/\\\"}"
        c="${c//$'\n'/\\n}"
        c="${c//$'\r'/\\r}"
        c="${c//$'\t'/\\t}"
        printf '{"v":1,"session_id":"%s","format":"%s","client_ip":"%s","ssh_tty":"%s","original_command":"%s","start":"%s"}' \
            "$SESSION_ID" "$FORMAT" "$CLIENT_IP" "$TTY_NAME" "$c" "$SESSION_START"
    fi
}

# Cleanup on exit. The sink owns the metadata file (end time + status), so the
# recorder no longer writes any session file here — it only tears down the
# timeout watchdog and logs.
cleanup() {
    local exit_code=$?

    if [ -n "$TIMEOUT_PID" ]; then
        kill "$TIMEOUT_PID" 2>/dev/null || true
        wait "$TIMEOUT_PID" 2>/dev/null || true
    fi

    log_info "Session $SESSION_ID ended for user $SESSION_USER (recorder rc: $exit_code)"
}

# Handle session timeout
handle_timeout() {
    log_warn "Session $SESSION_ID timed out after $MAX_SESSION_DURATION seconds"
    echo "Session timed out after $MAX_SESSION_DURATION seconds" >&2

    # Kill the recording process if running
    if [ -n "$RECORDING_PID" ]; then
        kill -TERM "$RECORDING_PID" 2>/dev/null || true
    fi

    exit 124  # Standard timeout exit code
}

# Detect non-interactive file-transfer commands that cannot tolerate a PTY.
# scp, sftp-server and rsync exchange a binary protocol over stdin/stdout;
# wrapping them in script/asciinema/ttyrec corrupts the stream (NL→CR+NL
# translation, terminal echo, etc.) and the client aborts with errors like
# "Connection closed" or "unexpected <newline>". Returns 0 if the command
# must be exec'd directly (no PTY), 1 otherwise.
is_file_transfer() {
    local cmd="${ORIGINAL_COMMAND:-}"
    [ -z "$cmd" ] && return 1
    local first="${cmd%%[[:space:]]*}"
    # Strip an optional leading path: ssh subsystem invocations come as
    # the full path defined by "Subsystem sftp ...".
    local base="${first##*/}"
    case "$base" in
        scp)
            # scp server-side is invoked as "scp -t <dir>" (to) or
            # "scp -f <file>" (from). The interactive 'scp' command on
            # the bastion itself would not have these flags.
            case " $cmd " in
                *" -t "*|*" -f "*) return 0 ;;
            esac
            ;;
        sftp-server|internal-sftp)
            return 0
            ;;
        rsync)
            # Server-side rsync is always invoked with --server.
            case " $cmd " in
                *" --server "*) return 0 ;;
            esac
            ;;
    esac
    return 1
}

# Exec a file-transfer command directly, bypassing the PTY recorder.
# Stdin/stdout/stderr stay raw so the SCP/SFTP/rsync protocol works. We still
# record the session (command, start/end) for audit by sending a metadata-only
# header to the sink (no stream). Recording is mandatory: if the sink is
# unreachable we refuse the transfer (fail-closed) rather than running unrecorded.
record_transfer() {
    local shell="${SHELL:-/bin/bash}"
    FORMAT="transfer"
    log_info "Session $SESSION_ID: file-transfer (no PTY recording): $ORIGINAL_COMMAND"
    # Send the header and let the sink finalize the transfer record. exec'ing
    # 'true' makes ob-record-connect send the header then close → the sink sees
    # header + immediate EOF and records a transfer session. A connect failure
    # returns non-zero WITHOUT running 'true', so we fail closed.
    if ! ob-record-connect "$(build_header)" true; then
        log_err "recording sink unreachable; refusing file transfer (fail-closed)"
        echo "Session recording is required but unavailable; transfer refused." >&2
        return 1
    fi
    # Run under the user's login shell so $PATH and aliases behave as usual.
    "$shell" -c "$ORIGINAL_COMMAND"
}

# Record an interactive/PTY session: stream the typescript straight into the
# recording sink over the socket. ob-record-connect connects, sends the header,
# and execs script with the connected socket at /dev/fd/3; script writes the
# typescript there. If the sink is unreachable ob-record-connect returns non-zero
# WITHOUT exec'ing script, so no shell starts — recording is mandatory when
# enabled (fail-closed; see the design §9).
record_script() {
    local shell="${SHELL:-/bin/bash}"
    local header
    header=$(build_header)

    # script runs the shell (or the original command) and writes the typescript
    # to /dev/fd/3 — the socket connected by ob-record-connect. -f flushes after
    # each write so the sink (and any live monitor) sees output promptly. The
    # `if !` form keeps `set -e` from exiting before we can report the failure.
    local target="$shell"
    [ -n "$ORIGINAL_COMMAND" ] && target="$ORIGINAL_COMMAND"

    if ! ob-record-connect "$header" script -q -f -c "$target" /dev/fd/3; then
        echo "Session recording is required but unavailable; access refused." >&2
        return 1
    fi
}

# NOTE: asciinema/ttyrec recording is not yet supported over the sink protocol
# (v1 streams typescript only). The format coercion in main() maps any other
# configured format to "script".

# Print usage
usage() {
    cat <<EOF
Usage: $PROG_NAME [OPTIONS]

Record SSH sessions for audit purposes.
Designed to be used as ForceCommand in sshd_config.

Options:
    -h, --help          Show this help message
    -v, --version       Show version
    -c, --config FILE   Configuration file (default: $CONFIG_FILE)
    -d, --dir DIR       Sessions directory (default: $SESSIONS_DIR)
    -f, --format FMT    Recording format: script, asciinema, ttyrec
                        (default: $FORMAT)

Configuration file format:
    sessions_dir = /var/lib/open-bastion/sessions
    format = script
    max_duration = 86400

sshd_config example:
    Match Group recorded-users
        ForceCommand /usr/sbin/ob-session-recorder

Environment variables:
    OB_RECORDER_CONFIG      Config file path
    OB_SESSIONS_DIR         Sessions directory
    OB_RECORDER_FORMAT      Recording format
    OB_MAX_SESSION          Max session duration in seconds

EOF
}

# Parse command line arguments
parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "$PROG_NAME version $VERSION"
                exit 0
                ;;
            -c|--config)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    log_err "Option $1 requires an argument"
                    exit 1
                fi
                CONFIG_FILE="$2"
                shift 2
                ;;
            -d|--dir)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    log_err "Option $1 requires an argument"
                    exit 1
                fi
                SESSIONS_DIR="$2"
                shift 2
                ;;
            -f|--format)
                if [ -z "${2:-}" ] || [[ "${2:-}" == -* ]]; then
                    log_err "Option $1 requires an argument"
                    exit 1
                fi
                FORMAT="$2"
                shift 2
                ;;
            *)
                log_err "Unknown option: $1"
                usage >&2
                exit 1
                ;;
        esac
    done
}

# Main
main() {
    parse_args "$@"

    # Security: session recorder should not run as root
    if [ "$(id -u)" -eq 0 ]; then
        log_warn "Session recorder should not run as root"
    fi

    load_config

    # Generate session ID and timestamps
    SESSION_ID=$(generate_session_id)
    SESSION_START=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    # The recording is now streamed to the root sink (ob-record-sink), which owns
    # the on-disk files under /var/lib/open-bastion/sessions/<user>/ so the user
    # cannot delete or alter them (#151). The recorder therefore creates no files
    # and no per-user directory. The recorder must be able to reach the sink.
    if ! command -v ob-record-connect >/dev/null 2>&1; then
        log_err "ob-record-connect not found; recording is required — refusing session"
        echo "Session recording is required but not installed; access refused." >&2
        exit 1
    fi

    # v1 streams typescript only. asciinema/ttyrec are not yet supported over the
    # sink protocol; fall back to script rather than silently misbehaving.
    if [ "$FORMAT" != "script" ]; then
        [ "$FORMAT" != "transfer" ] && log_warn "format '$FORMAT' not supported by the sink yet; using 'script'"
        FORMAT="script"
    fi

    log_info "Session $SESSION_ID started for user $SESSION_USER from $CLIENT_IP"

    # Setup cleanup trap
    trap cleanup EXIT
    trap handle_timeout ALRM

    # Set session timeout (in background).
    #
    # CRITICAL: redirect stdin/stdout/stderr to /dev/null. Without this, the
    # background subshell inherits the SSH channel's FDs from sshd; sshd then
    # waits for ALL processes holding those FDs to release them before closing
    # the channel. For interactive sessions this is masked because the user's
    # shell holds the channel anyway, but for scp/sftp/rsync the transfer
    # finishes cleanly yet "the command hangs" because sshd is waiting on the
    # leaked sleep child. See: https://serverfault.com/q/342436
    #
    # We also trap TERM in the subshell to kill the sleep grandchild on
    # cleanup, so we don't leak a sleep process for MAX_SESSION_DURATION.
    if [ "$MAX_SESSION_DURATION" -gt 0 ]; then
        local parent_pid=$$
        (
            trap 'kill "${sleep_pid:-0}" 2>/dev/null; exit 0' TERM HUP
            sleep "$MAX_SESSION_DURATION" &
            sleep_pid=$!
            wait "$sleep_pid" 2>/dev/null
            kill -ALRM "$parent_pid" 2>/dev/null || true
        ) </dev/null >/dev/null 2>&1 &
        TIMEOUT_PID=$!
    fi

    # File-transfer commands (scp, sftp, rsync) need raw stdio: bypass the PTY
    # recorder, record metadata only. Otherwise stream the PTY typescript to the
    # sink. Both paths fail closed when the sink is unreachable.
    if is_file_transfer; then
        record_transfer
    else
        record_script
    fi
}

main "$@"
