#
# LemonLDAP::NG Session Recorder Configuration
#
# This file configures the ob-session-recorder script used to
# record SSH sessions on bastion hosts for audit purposes.
#

# Directory where session recordings are stored
# Each user gets a subdirectory: /var/lib/open-bastion/sessions/<username>/
sessions_dir = /var/lib/open-bastion/sessions

# Recording format:
#   script    - Plain text typescript (default, always available)
#   asciinema - JSON format, web-friendly (requires asciinema package)
#   ttyrec    - Binary format, compact (requires ttyrec package)
format = script

# Maximum session duration in seconds (default: 86400 = 24 hours)
# Sessions exceeding this limit will be terminated
# Set to 0 to disable timeout
max_duration = 86400

# Retention of recordings, applied daily by ob-session-prune.timer.
# Recording is fail-closed: a full disk refuses new logins, so recordings are
# compressed and eventually expired to bound disk usage.
#
# Compress closed recordings (typescripts compress ~10-20x) older than this many
# days. The paired .json metadata is left uncompressed. Set to 0 to disable.
recording_compress_after_days = 1
#
# Delete recordings (payload + .json) older than this many days. Expiry drops
# audit evidence and is logged at notice level. Set to 0 to keep forever.
recording_retention_days = 365

#
# sshd_config integration example:
#
# To record all sessions for users in the "recorded-users" group:
#
#   Match Group recorded-users
#       ForceCommand /usr/sbin/ob-session-recorder
#
# To record all sessions except for specific users:
#
#   Match User *,!admin,!root
#       ForceCommand /usr/sbin/ob-session-recorder
#
# To record sessions with a specific format:
#
#   Match Group audited
#       ForceCommand /usr/sbin/ob-session-recorder -f ttyrec
#
