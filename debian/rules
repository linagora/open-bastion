#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DENABLE_CACHE=ON \
		-DUSE_LIBSODIUM=ON \
		-DINSTALL_SYSTEMD=OFF \
		-DINSTALL_DESKTOP=ON

override_dh_auto_install:
	dh_auto_install
	# Stage the admin-builder tree so debian/open-bastion-builder.install
	# can pick it up. The builder is a pure-bash tool that CMake does not
	# need to compile; we install it from source directly.
	install -Dm 0755 admin-builder/ob-builder debian/tmp/usr/bin/ob-builder
	install -dm 0755 debian/tmp/usr/share/open-bastion-builder/lib
	install -dm 0755 debian/tmp/usr/share/open-bastion-builder/templates
	install -dm 0755 debian/tmp/usr/share/open-bastion-builder/keyrings
	cp -a admin-builder/lib/.       debian/tmp/usr/share/open-bastion-builder/lib/
	cp -a admin-builder/templates/. debian/tmp/usr/share/open-bastion-builder/templates/
	cp -a admin-builder/keyrings/.  debian/tmp/usr/share/open-bastion-builder/keyrings/
	install -Dm 0644 admin-builder/man/ob-builder.1 debian/tmp/usr/share/man/man1/ob-builder.1

# NSS and PAM modules need ldconfig but no development symlinks
override_dh_makeshlibs:
	dh_makeshlibs -X/security/

# Install systemd units for each package
override_dh_installsystemd:
	dh_installsystemd -popen-bastion --name=ob-heartbeat ob-heartbeat.timer
	# Session-recording retention timer: enabled and started at install (no
	# ConditionPathExists gate, unlike ob-heartbeat.timer, so it actually arms).
	# It bounds recording disk usage and no-ops on hosts without recordings.
	dh_installsystemd -popen-bastion --name=ob-session-prune ob-session-prune.timer
	# Cert minting socket. dh_installsystemd installs the .socket (the
	# package.NAME.socket FILES form, via --name) and generates its enable/cleanup
	# maintainer-script blocks. The accompanying ob-cert@.service TEMPLATE is
	# installed via debian/open-bastion.install (dh_installsystemd does not
	# auto-install named template units, and a template is never "enabled" — the
	# .socket pulls in instances). Not enabled/started at install — ob-bastion-setup
	# activates it (bastion/standalone only).
	dh_installsystemd -popen-bastion --no-enable --no-start --name=ob-cert ob-cert.socket
	# Session-recording sink socket (same arrangement; ob-record@.service template
	# is installed via debian/open-bastion.install).
	dh_installsystemd -popen-bastion --no-enable --no-start --name=ob-record ob-record.socket
	dh_installsystemd -popen-bastion-desktop --name=ob-session-monitor ob-session-monitor.service
