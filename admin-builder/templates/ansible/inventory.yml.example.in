---
# Open Bastion inventory example — auto-generated by ob-builder @@OB_BUILDER_VERSION@@
# Slug: @@DEPLOYMENT_SLUG@@
#
# The ob_server_group variable is intentionally set per-host (or per-group).
# The deployment artifact is shared across the fleet, but each host belongs
# to the server group it was assigned in the LLNG portal.
#
# Override ob_client_secret per-host (or group_vars) via ansible-vault:
#   ansible-vault encrypt_string 's3cr3t' --name ob_client_secret

all:
  children:

    # Bastion hosts — accept inbound SSH from users
    bastions:
      hosts:
        bastion-01.example.com:
          ob_server_group: "@@SERVER_GROUP@@"
        bastion-02.example.com:
          ob_server_group: "@@SERVER_GROUP@@"

    # Backend (target) hosts — accept SSH forwarded from bastions
    backends:
      hosts:
        backend-01.example.com:
          ob_server_group: "@@SERVER_GROUP@@"
        backend-02.example.com:
          # Each host may belong to a different group
          ob_server_group: "@@SERVER_GROUP@@"

    # Standalone hosts — act as bastion and backend simultaneously
    standalones:
      hosts:
        standalone-01.example.com:
          ob_server_group: "@@SERVER_GROUP@@"
