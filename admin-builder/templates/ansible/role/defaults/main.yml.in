---
# Open Bastion Ansible role — default variables
# Auto-generated by ob-builder @@OB_BUILDER_VERSION@@
# Build: @@BUILD_DATE@@ | Slug: @@DEPLOYMENT_SLUG@@
#
# These values are baked in at build time. Override them via:
#   - host_vars/<hostname>.yml
#   - group_vars/<groupname>.yml
#   - ansible-playbook --extra-vars
#   - ansible-vault (recommended for ob_client_secret)

# ── Deployment metadata ───────────────────────────────────────────────────────
ob_deployment_slug: "@@DEPLOYMENT_SLUG@@"
ob_scenario: "@@SCENARIO@@"
ob_pam_mode: "@@PAM_MODE@@"
ob_role: "@@TARGET_ROLE@@"  # bastion | standalone | backend
ob_max_security: @@MAX_SECURITY_BOOL@@  # true when ob_pam_mode == E

# ── OIDC / portal settings ────────────────────────────────────────────────────
ob_portal_url: "@@PORTAL_URL@@"
ob_client_id: "@@CLIENT_ID@@"
# Verify the portal's TLS certificate. Keep true in production (HTTPS portal).
# Set false ONLY for a plain-http or self-signed test portal: it makes
# ob-*-setup pass --insecure and writes verify_ssl=false so pam_openbastion
# accepts the non-HTTPS portal (it refuses http unless verify_ssl is false).
ob_verify_ssl: true
# ob_client_secret — provided at runtime when client_secret_mode=prompt
# (use ansible-vault), or baked here when client_secret_mode=embedded.
# Embedded mode trades convenience for risk: anyone with read access to this
# defaults file (or the generated tarball) can read the secret.
ob_client_secret_mode: "@@CLIENT_SECRET_MODE@@"
ob_client_secret: "@@EMBEDDED_CLIENT_SECRET@@"
ob_server_group: "@@SERVER_GROUP@@"

# ── Enrollment / setup automation ────────────────────────────────────────────
# When true, the role runs ob-enroll during the play.
# Note: ob-enroll uses Device Authorization Grant. By default the admin must
# open the printed URL in a browser to approve the request; this role can
# automate that approval when ob_ansible_auto_approve is true AND an LLNG
# session cookie is supplied at play time (see below).
ob_auto_enroll: @@AUTO_ENROLL_BOOL@@  # true when AUTO_ENROLL_SETUP includes enrollment

# When true, the role runs ob-bastion-setup / ob-backend-setup during the play.
ob_auto_setup: @@AUTO_SETUP_BOOL@@

# ── Optional opt-in features ──────────────────────────────────────────────────
# Hardening and audit-trace are intrusive/system-wide and default to false
# (see SECURITY.md). They apply to every role. Session recording is ON by
# default on bastion/standalone; set ob_disable_session_recorder to true to opt
# out (no effect for the backend role, which never records sessions).
ob_enable_hardening: @@ENABLE_HARDENING_BOOL@@
ob_enable_audit_trace: @@ENABLE_AUDIT_TRACE_BOOL@@
ob_disable_session_recorder: @@DISABLE_SESSION_RECORDER_BOOL@@

# ── Service accounts (SSH-key-only local accounts) ────────────────────────────
# Baked in at build time. ob_service_accounts_content is the full INI body of
# /etc/open-bastion/service-accounts.conf (see doc/service-accounts.md). Override
# per host/group via host_vars/group_vars to vary which accounts reach which
# servers. Empty content + enabled:false means no service accounts are deployed.
@@SERVICE_ACCOUNTS_DEFAULTS_YAML@@

# ── Device-code auto-approval (Ansible-only, opt-in at build time) ───────────
# When ob_ansible_auto_approve is true AND ob_llng_cookie is non-empty, the
# enrollment task auto-approves the user_code via the LLNG /device endpoint
# instead of waiting for a human to validate it in a browser. The cookie is
# obtained with the `llng` CLI from simple-oidc-client:
#   llng --llng-server <portal> llng_cookie
# It is asked for at every play run via vars_prompt in playbook.yml and is
# never persisted to disk. Falls back to the manual flow if the cookie is empty.
ob_ansible_auto_approve: @@ANSIBLE_AUTO_APPROVE_BOOL@@
ob_llng_cookie: ""

# Controller-side approval reachability override (optional). The device-code
# approval runs on the Ansible control node and talks to the portal directly.
# By default it uses ob_portal_url. Set these only when the control node reaches
# the portal at a different address than the managed hosts do (split-horizon
# DNS, NAT, a lab behind a gateway):
#   ob_approve_base_url: base URL the controller uses, e.g. "http://10.0.0.1"
#   ob_approve_host:     Host: header to send (the portal's vhost name)
# Left unset here so the portal URL is used unchanged.

# ── APT repository ────────────────────────────────────────────────────────────
ob_apt_sources_list_line: "@@APT_SOURCES_LIST@@"

# ── Mode-specific config keys ─────────────────────────────────────────────────
# Expanded by ob-builder from the selected PAM mode (@@PAM_MODE@@).
@@MODE_SETTINGS_YAML@@

# ── Backend-only: "accept only this bastion" ──────────────────────────────────
# Empty for bastion/standalone roles. For backend roles ob-builder expands this
# to ob_bastion_allowed_bastions (comma/space-separated bastion_id = enrolling
# client_id) when an allowlist was given at build time. Enforcement is via
# ob-backend-setup (AuthorizedPrincipalsCommand + cert source-address), not the
# old broken bastion_jwt config.
@@BASTION_ALLOWLIST_VARS_YAML@@
