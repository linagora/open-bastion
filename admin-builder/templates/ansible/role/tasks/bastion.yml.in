---
# Open Bastion — bastion role tasks
# Auto-generated by ob-builder @@OB_BUILDER_VERSION@@
# Scenario: @@SCENARIO@@ (Mode @@PAM_MODE@@)

# ob-enroll uses Device Authorization Grant.  When ob_auto_enroll is true,
# the task will print a URL that an admin must open in a browser to approve
# the device.  Ansible cannot bypass that interactive step; it waits for
# ob-enroll to return.  The client secret is passed via environment variable
# to keep it out of /proc/<pid>/cmdline.
- name: Enroll bastion with LLNG (ob-enroll)
  ansible.builtin.command:
    argv:
      - /usr/sbin/ob-enroll
      - -g
      - "{{ ob_server_group }}"
      - --quiet
  environment:
    OB_CLIENT_SECRET: "{{ ob_client_secret }}"
  when: ob_auto_enroll
  changed_when: true

- name: Configure bastion (ob-bastion-setup)
  ansible.builtin.command:
    argv: >-
      {{
        ['/usr/sbin/ob-bastion-setup',
         '--portal-url', ob_portal_url,
         '-g', ob_server_group,
         '--non-interactive']
        + (['--max-security'] if ob_max_security else [])
      }}
  environment:
    OB_CLIENT_SECRET: "{{ ob_client_secret }}"
  when: ob_auto_setup
  changed_when: true
