---
# Open Bastion — backend role tasks
# Auto-generated by ob-builder @@OB_BUILDER_VERSION@@
# Scenario: @@SCENARIO@@ (Mode @@PAM_MODE@@)

# Enrollment uses Device Authorization Grant. By default the admin must open
# the printed URL and approve in a browser; if ob_ansible_auto_approve was
# enabled at build time and an LLNG cookie is provided at play time, the
# included tasks below approve the device code via the LLNG /device endpoint
# instead, so the play can run unattended on a fleet.
- name: "Run enrollment flow (auto-approve or manual)"
  ansible.builtin.include_tasks: _enroll.yml
  when: ob_auto_enroll
  vars:
    ob_role: backend

- name: Configure backend (ob-backend-setup)
  ansible.builtin.command:
    argv: >-
      {{
        ['/usr/sbin/ob-backend-setup',
         '--portal', ob_portal_url,
         '-g', ob_server_group,
         '-c', ob_client_id,
         '--yes']
        + (['--insecure'] if not (ob_verify_ssl | default(true)) else [])
        + (['--allowed-bastions', ob_bastion_allowed_bastions]
           if ob_bastion_allowed_bastions is defined else [])
        + (['--max-security'] if ob_max_security else [])
        + (['--enable-hardening'] if ob_enable_hardening else [])
        + (['--enable-audit-trace'] if ob_enable_audit_trace else [])
      }}
  environment:
    OB_CLIENT_SECRET: "{{ ob_client_secret }}"
  when: ob_auto_setup
  changed_when: true
