---
# Open Bastion — main task entry point
# Auto-generated by ob-builder @@OB_BUILDER_VERSION@@
# Scenario: @@SCENARIO@@ (Mode @@PAM_MODE@@) | Role: @@TARGET_ROLE@@

- name: Pre-checks
  ansible.builtin.assert:
    that:
      - ob_portal_url is defined and ob_portal_url | length > 0
      - ob_role in ['bastion', 'standalone', 'backend']
      - ob_pam_mode in ['A', 'B', 'C', 'D', 'E']
    fail_msg: >-
      Required variables are missing or invalid.
      Set ob_portal_url, ob_role (bastion|standalone|backend),
      and ob_pam_mode (A-E).

- name: Install prerequisites
  ansible.builtin.apt:
    name:
      - gnupg
      - curl
      - apt-transport-https
    state: present
    update_cache: true
  when: ansible_facts['os_family'] == 'Debian'

- name: Deploy APT keyring
  ansible.builtin.copy:
    src: open-bastion.gpg
    dest: /etc/apt/keyrings/open-bastion.gpg
    owner: root
    group: root
    mode: '0644'
  when: ansible_facts['os_family'] == 'Debian'

- name: Deploy APT sources.list entry
  ansible.builtin.copy:
    content: "{{ ob_apt_sources_list_line }}\n"
    dest: /etc/apt/sources.list.d/open-bastion.list
    owner: root
    group: root
    mode: '0644'
  when: ansible_facts['os_family'] == 'Debian'

- name: Install open-bastion package
  ansible.builtin.apt:
    name: open-bastion
    state: present
    update_cache: true
  when: ansible_facts['os_family'] == 'Debian'

- name: Create /etc/open-bastion directory
  ansible.builtin.file:
    path: /etc/open-bastion
    state: directory
    owner: root
    group: root
    mode: '0700'

- name: Deploy SSH CA public key
  ansible.builtin.copy:
    src: open-bastion-ca.pub
    dest: /etc/ssh/open-bastion_ca.pub
    owner: root
    group: root
    mode: '0644'

# KRL (Key Revocation List) is mandatory in Mode E — certificate revocation
# requires an up-to-date KRL on every bastion and backend.
- name: Deploy KRL
  ansible.builtin.copy:
    src: open-bastion-krl
    dest: /etc/ssh/revoked_keys
    owner: root
    group: root
    mode: '0644'
  when: ob_max_security

- name: Deploy openbastion.conf
  ansible.builtin.template:
    src: openbastion.conf.j2
    dest: /etc/open-bastion/openbastion.conf
    owner: root
    group: root
    mode: '0600'
  notify: Restart sshd

- name: Dispatch role-specific tasks
  ansible.builtin.include_tasks: "{{ ob_role }}.yml"
