#!/usr/bin/env bash
# Open Bastion bootstrap — auto-generated by ob-builder @@OB_BUILDER_VERSION@@
# Build date:  @@BUILD_DATE@@
# Slug:        @@DEPLOYMENT_SLUG@@
# Scenario:    @@SCENARIO@@ (Mode @@PAM_MODE@@)
# Role:        @@TARGET_ROLE@@
# SSO:         @@PORTAL_URL@@
#
# USAGE:
#   ./open-bastion-bootstrap-@@DEPLOYMENT_SLUG@@.sh [OPTIONS] [info]
#
# Run with --help for full option list.

set -euo pipefail

# ---------------------------------------------------------------------------
# Embedded metadata (build-time constants)
# ---------------------------------------------------------------------------

OB_BUILDER_VERSION="@@OB_BUILDER_VERSION@@"
BUILD_DATE="@@BUILD_DATE@@"
DEPLOYMENT_SLUG="@@DEPLOYMENT_SLUG@@"
SCENARIO="@@SCENARIO@@"
PAM_MODE="@@PAM_MODE@@"
TARGET_ROLE="@@TARGET_ROLE@@"
PORTAL_URL_DEFAULT="@@PORTAL_URL@@"
CA_SSH_FINGERPRINT="@@CA_SSH_FINGERPRINT@@"

# Policies (fixed | modifiable)
CLIENT_ID_POLICY="@@CLIENT_ID_POLICY@@"
SERVER_GROUP_POLICY="@@SERVER_GROUP_POLICY@@"
# Embedded defaults (may be empty if modifiable with no default)
CLIENT_ID_EMBEDDED="@@CLIENT_ID@@"
SERVER_GROUP_EMBEDDED="@@SERVER_GROUP@@"

# client_secret mode: none | prompt | embedded
CLIENT_SECRET_MODE="@@CLIENT_SECRET_MODE@@"

# Embedded client_secret — populated only when CLIENT_SECRET_MODE=embedded.
# WARNING: this artefact contains the OIDC client_secret. Anyone who can read
# this file can read the secret (base64 is encoding, not encryption).
# The value is base64-encoded so secrets containing shell metacharacters
# ($, `, ", \) cannot break out of the bash literal — i.e. cannot achieve
# code execution as root during install.
EMBEDDED_CLIENT_SECRET_B64="@@EMBEDDED_CLIENT_SECRET_B64@@"

# Enroll/setup automation: yes | no | prompt
AUTO_ENROLL_SETUP="@@AUTO_ENROLL_SETUP@@"

# Self-delete after success: yes | no
SELF_DELETE_DEFAULT="@@SELF_DELETE@@"

# Optional opt-in features passed through to ob-{bastion,backend}-setup
# (yes | no). Hardening and audit-trace are intrusive and default to no.
# DISABLE_SESSION_RECORDER=yes opts out of session recording on a
# bastion/standalone (no effect for the backend role, which never records).
ENABLE_HARDENING="@@ENABLE_HARDENING@@"
ENABLE_AUDIT_TRACE="@@ENABLE_AUDIT_TRACE@@"
DISABLE_SESSION_RECORDER="@@DISABLE_SESSION_RECORDER@@"

# ---------------------------------------------------------------------------
# Runtime variables (resolved during execution)
# ---------------------------------------------------------------------------

PORTAL_URL="${PORTAL_URL_DEFAULT}"
CLIENT_ID=""
SERVER_GROUP=""
CLIENT_SECRET=""

# Flags from CLI parsing
OPT_CLIENT_ID=""
OPT_CLIENT_ID_SET=false
OPT_SERVER_GROUP=""
OPT_SERVER_GROUP_SET=false
OPT_CLIENT_SECRET=""
OPT_CLIENT_SECRET_FILE=""
OPT_PORTAL_URL=""
OPT_YES=false
OPT_SKIP_ENROLL=false
OPT_SKIP_SETUP=false
OPT_SKIP_INSTALL=false
OPT_DRY_RUN=false
OPT_FORCE=false
OPT_NON_INTERACTIVE=false
OPT_INSECURE=false
OPT_SELF_DELETE=""   # "", "yes" or "no" — empty means honour SELF_DELETE_DEFAULT

DISTRO=""  # debian | rhel

# ---------------------------------------------------------------------------
# Logging helpers
# ---------------------------------------------------------------------------

if [ -t 1 ]; then
    _RED='\033[0;31m'
    _GREEN='\033[0;32m'
    _YELLOW='\033[1;33m'
    _BLUE='\033[0;34m'
    _NC='\033[0m'
else
    _RED=''
    _GREEN=''
    _YELLOW=''
    _BLUE=''
    _NC=''
fi

log_step()  { printf '%s[STEP]%s %s\n' "${_BLUE}"   "${_NC}" "$*"; }
log_info()  { printf '%s[INFO]%s %s\n' "${_GREEN}"  "${_NC}" "$*"; }
log_warn()  { printf '%s[WARN]%s %s\n' "${_YELLOW}" "${_NC}" "$*" >&2; }
log_error() { printf '%s[ERROR]%s %s\n' "${_RED}"   "${_NC}" "$*" >&2; }
die()       { log_error "$*"; exit 1; }

# ---------------------------------------------------------------------------
# CLI parsing
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
Usage: ./open-bastion-bootstrap-${DEPLOYMENT_SLUG}.sh [OPTIONS] [info]

Subcommands:
  info    Print embedded scenario metadata and exit (no system changes).

Options:
  --client-id ID            Override client_id${CLIENT_ID_POLICY:+ (policy: ${CLIENT_ID_POLICY})}
  --client-secret SECRET    Provide client_secret without prompt
                            (insecure — visible in /proc; prefer --client-secret-file)
  --client-secret-file PATH Read client_secret from file (use - for stdin)
  --server-group GROUP      Override server_group${SERVER_GROUP_POLICY:+ (policy: ${SERVER_GROUP_POLICY})}
  --portal-url URL          Override SSO portal URL
  -y, --yes                 Answer Y to all prompts (enroll + setup run automatically)
  --skip-enroll             Deploy config and install package, skip ob-enroll
  --skip-setup              Run ob-enroll but skip ob-{bastion,backend}-setup
  --skip-install            Don't install the open-bastion package (assume it
                            is already present, e.g. built from source)
  --dry-run                 Print actions without executing them
  --force                   Overwrite existing /etc/open-bastion (normally refused)
  --non-interactive         Fail instead of prompting (for CI)
  --insecure                Disable TLS verification (debug only)
  --self-delete             Remove this installer from disk after success
                            (overrides the built-in default: ${SELF_DELETE_DEFAULT})
  --no-self-delete          Keep the installer on disk after success
  -h, --help                Show this help

Embedded metadata:
  Scenario:   ${SCENARIO} (Mode ${PAM_MODE})
  Role:       ${TARGET_ROLE}
  SSO portal: ${PORTAL_URL_DEFAULT}
  CA SHA256:  ${CA_SSH_FINGERPRINT}

EOF
    exit 0
}

parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            info)
                cmd_info
                ;;
            --client-id)
                [ -n "${2:-}" ] || die "--client-id requires an argument"
                OPT_CLIENT_ID="$2"; OPT_CLIENT_ID_SET=true; shift 2 ;;
            --client-secret)
                [ -n "${2:-}" ] || die "--client-secret requires an argument"
                OPT_CLIENT_SECRET="$2"; shift 2 ;;
            --client-secret-file)
                [ -n "${2:-}" ] || die "--client-secret-file requires an argument"
                OPT_CLIENT_SECRET_FILE="$2"; shift 2 ;;
            --server-group)
                [ -n "${2:-}" ] || die "--server-group requires an argument"
                OPT_SERVER_GROUP="$2"; OPT_SERVER_GROUP_SET=true; shift 2 ;;
            --portal-url)
                [ -n "${2:-}" ] || die "--portal-url requires an argument"
                OPT_PORTAL_URL="$2"; shift 2 ;;
            -y|--yes)
                OPT_YES=true; shift ;;
            --skip-enroll)
                OPT_SKIP_ENROLL=true; shift ;;
            --skip-setup)
                OPT_SKIP_SETUP=true; shift ;;
            --skip-install)
                OPT_SKIP_INSTALL=true; shift ;;
            --dry-run)
                OPT_DRY_RUN=true; shift ;;
            --force)
                OPT_FORCE=true; shift ;;
            --non-interactive)
                OPT_NON_INTERACTIVE=true; shift ;;
            --insecure)
                OPT_INSECURE=true; shift ;;
            --self-delete)
                OPT_SELF_DELETE=yes; shift ;;
            --no-self-delete)
                OPT_SELF_DELETE=no; shift ;;
            -h|--help)
                usage ;;
            *)
                die "Unknown option: $1 (use --help for usage)" ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# info subcommand — print metadata, no side effects
# ---------------------------------------------------------------------------

cmd_info() {
    echo "Open Bastion Bootstrap"
    echo "  Builder version: ${OB_BUILDER_VERSION}"
    echo "  Build date:      ${BUILD_DATE}"
    echo "  Slug:            ${DEPLOYMENT_SLUG}"
    echo "  Scenario:        ${SCENARIO} (Mode ${PAM_MODE})"
    echo "  Target role:     ${TARGET_ROLE}"
    echo "  SSO portal:      ${PORTAL_URL_DEFAULT}"
    echo "  Client ID:       ${CLIENT_ID_EMBEDDED:-<not embedded>} (policy: ${CLIENT_ID_POLICY})"
    echo "  Server group:    ${SERVER_GROUP_EMBEDDED:-<not embedded>} (policy: ${SERVER_GROUP_POLICY})"
    echo "  Secret mode:     ${CLIENT_SECRET_MODE}"
    echo "  Auto enroll:     ${AUTO_ENROLL_SETUP}"
    echo "  CA fingerprint:  ${CA_SSH_FINGERPRINT}"
    exit 0
}

# ---------------------------------------------------------------------------
# Override resolution — precedence: CLI flag > env var > embedded default > prompt
# Honors *_POLICY=fixed: refuses override and warns if user tries.
# ---------------------------------------------------------------------------

resolve_client_id() {
    if [ "${CLIENT_ID_POLICY}" = "fixed" ]; then
        if [ "${OPT_CLIENT_ID_SET}" = "true" ]; then
            log_warn "--client-id ignored: client_id is fixed in this artifact (policy=fixed)"
        fi
        if [ -n "${OB_CLIENT_ID:-}" ]; then
            log_warn "OB_CLIENT_ID ignored: client_id is fixed in this artifact (policy=fixed)"
        fi
        CLIENT_ID="${CLIENT_ID_EMBEDDED}"
        return
    fi
    # modifiable
    if [ "${OPT_CLIENT_ID_SET}" = "true" ]; then
        CLIENT_ID="${OPT_CLIENT_ID}"
    elif [ -n "${OB_CLIENT_ID:-}" ]; then
        CLIENT_ID="${OB_CLIENT_ID}"
    elif [ -n "${CLIENT_ID_EMBEDDED}" ]; then
        CLIENT_ID="${CLIENT_ID_EMBEDDED}"
    else
        # prompt or fail
        if [ "${OPT_NON_INTERACTIVE}" = "true" ]; then
            die "client_id is required but not set (no default embedded; pass --client-id or OB_CLIENT_ID)"
        fi
        printf "OIDC client_id [pam-access]: " >&2
        IFS= read -r CLIENT_ID < /dev/tty
        CLIENT_ID="${CLIENT_ID:-pam-access}"
    fi
}

resolve_server_group() {
    if [ "${SERVER_GROUP_POLICY}" = "fixed" ]; then
        if [ "${OPT_SERVER_GROUP_SET}" = "true" ]; then
            log_warn "--server-group ignored: server_group is fixed in this artifact (policy=fixed)"
        fi
        if [ -n "${OB_SERVER_GROUP:-}" ]; then
            log_warn "OB_SERVER_GROUP ignored: server_group is fixed in this artifact (policy=fixed)"
        fi
        SERVER_GROUP="${SERVER_GROUP_EMBEDDED}"
        return
    fi
    # modifiable
    if [ "${OPT_SERVER_GROUP_SET}" = "true" ]; then
        SERVER_GROUP="${OPT_SERVER_GROUP}"
    elif [ -n "${OB_SERVER_GROUP:-}" ]; then
        SERVER_GROUP="${OB_SERVER_GROUP}"
    elif [ -n "${SERVER_GROUP_EMBEDDED}" ]; then
        SERVER_GROUP="${SERVER_GROUP_EMBEDDED}"
    else
        if [ "${OPT_NON_INTERACTIVE}" = "true" ]; then
            die "server_group is required but not set (no default embedded; pass --server-group or OB_SERVER_GROUP)"
        fi
        printf "Server group (must match a group defined in LLNG): " >&2
        IFS= read -r SERVER_GROUP < /dev/tty
        [ -n "${SERVER_GROUP}" ] || die "server_group cannot be empty"
    fi
}

resolve_client_secret() {
    if [ "${CLIENT_SECRET_MODE}" = "none" ]; then
        CLIENT_SECRET=""
        return
    fi
    # Precedence: CLI flag > --client-secret-file > OB_CLIENT_SECRET env var
    #           > embedded value (if CLIENT_SECRET_MODE=embedded) > prompt
    if [ -n "${OPT_CLIENT_SECRET}" ]; then
        CLIENT_SECRET="${OPT_CLIENT_SECRET}"
    elif [ -n "${OPT_CLIENT_SECRET_FILE}" ]; then
        if [ "${OPT_CLIENT_SECRET_FILE}" = "-" ]; then
            IFS= read -r CLIENT_SECRET
        else
            [ -f "${OPT_CLIENT_SECRET_FILE}" ] || die "client_secret file not found: ${OPT_CLIENT_SECRET_FILE}"
            # Strip trailing CR/LF so files ending with a newline (most editors)
            # do not inject whitespace into the OIDC request.
            CLIENT_SECRET=$(tr -d '\r\n' < "${OPT_CLIENT_SECRET_FILE}")
        fi
    elif [ -n "${OB_CLIENT_SECRET:-}" ]; then
        CLIENT_SECRET="${OB_CLIENT_SECRET}"
    elif [ "${CLIENT_SECRET_MODE}" = "embedded" ]; then
        CLIENT_SECRET=$(printf '%s' "${EMBEDDED_CLIENT_SECRET_B64}" | base64 -d 2>/dev/null || true)
        if [ -z "${CLIENT_SECRET}" ]; then
            die "embedded client_secret decode failed (artefact may be corrupted)"
        fi
        log_warn "Using embedded client_secret from artefact (clear-text after decode)."
    else
        if [ "${OPT_NON_INTERACTIVE}" = "true" ]; then
            die "client_secret required but not provided (pass --client-secret-file or set OB_CLIENT_SECRET)"
        fi
        printf "client_secret for OIDC RP (input hidden): " >&2
        IFS= read -rs CLIENT_SECRET < /dev/tty
        echo "" >&2
    fi
}

# ---------------------------------------------------------------------------
# System helpers
# ---------------------------------------------------------------------------

require_root() {
    [ "$(id -u)" -eq 0 ] || die "This script must be run as root"
}

detect_distro() {
    if [ -f /etc/os-release ]; then
        # shellcheck source=/dev/null
        . /etc/os-release
        case "${ID:-}" in
            debian|ubuntu|linuxmint|pop|elementary|zorin|kali|parrot)
                DISTRO="debian" ;;
            rhel|centos|rocky|almalinux|fedora|ol)
                DISTRO="rhel" ;;
            *)
                case "${ID_LIKE:-}" in
                    *debian*)  DISTRO="debian" ;;
                    *rhel*|*fedora*) DISTRO="rhel" ;;
                    *) DISTRO="unknown" ;;
                esac
                ;;
        esac
    else
        DISTRO="unknown"
    fi
    log_info "Detected distribution family: ${DISTRO}"
}

# Atomic write: write to .tmp then mv (avoids partial reads)
atomic_write() {
    local dst="$1"
    local content="$2"
    local mode="${3:-0644}"
    local tmp
    tmp=$(mktemp "${dst}.XXXXXX")
    printf '%s' "${content}" > "${tmp}"
    chmod "${mode}" "${tmp}"
    mv -f "${tmp}" "${dst}"
}

prompt_yn() {
    local msg="$1"
    local default="${2:-y}"  # y or n
    if [ "${OPT_YES}" = "true" ]; then
        return 0
    fi
    if [ "${OPT_NON_INTERACTIVE}" = "true" ]; then
        die "--non-interactive set but a yes/no prompt is required: \"${msg}\". Pass --yes to confirm all, or --skip-enroll/--skip-setup to skip the relevant step."
    fi
    local prompt
    if [ "${default}" = "y" ]; then
        prompt="${msg} [Y/n] "
    else
        prompt="${msg} [y/N] "
    fi
    printf '%s' "${prompt}" >&2
    IFS= read -r _answer < /dev/tty
    case "${_answer:-${default}}" in
        [yY]*) return 0 ;;
        *)     return 1 ;;
    esac
}

# ---------------------------------------------------------------------------
# Precheck — refuse if /etc/open-bastion already exists (unless --force)
# ---------------------------------------------------------------------------

precheck() {
    if [ -e /etc/open-bastion ] && [ "${OPT_FORCE}" != "true" ]; then
        log_error "/etc/open-bastion already exists."
        log_error "Re-running this bootstrap would overwrite an existing installation."
        log_error "Use --force to override (this will replace all configuration)."
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Step 1 — Deposit APT/YUM repo and GPG key
# ---------------------------------------------------------------------------

step_repo() {
    log_step "1/5  Installing package repository"

    if [ "${DISTRO}" = "rhel" ]; then
        log_warn "RHEL/RPM-based system detected. This artifact embeds an APT sources entry."
        log_warn "APT repository configuration skipped. Configure the Open Bastion RPM repository manually."
        log_warn "Then re-run this script with --skip-enroll --skip-setup to resume from package install."
        return 0
    fi

    # Deposit GPG keyring
    if [ "${OPT_DRY_RUN}" = "true" ]; then
        log_info "[DRY-RUN] Would write /etc/apt/keyrings/open-bastion.gpg"
        log_info "[DRY-RUN] Would write /etc/apt/sources.list.d/open-bastion.list"
        return 0
    fi

    mkdir -p /etc/apt/keyrings
    # Decode embedded GPG key (base64-encoded)
    # shellcheck disable=SC2016
    base64 -d > /etc/apt/keyrings/open-bastion.gpg.tmp << 'OB_GPG_EOF'
@@GPG_KEY_B64@@
OB_GPG_EOF
    chmod 0644 /etc/apt/keyrings/open-bastion.gpg.tmp
    mv -f /etc/apt/keyrings/open-bastion.gpg.tmp /etc/apt/keyrings/open-bastion.gpg
    log_info "GPG keyring written: /etc/apt/keyrings/open-bastion.gpg"

    atomic_write /etc/apt/sources.list.d/open-bastion.list \
        "@@APT_SOURCES_LIST@@
" 0644
    log_info "APT sources written: /etc/apt/sources.list.d/open-bastion.list"
}

# ---------------------------------------------------------------------------
# Step 2 — Deposit /etc/open-bastion configuration
# ---------------------------------------------------------------------------

step_config() {
    log_step "2/5  Deploying /etc/open-bastion"

    resolve_client_id
    resolve_server_group
    resolve_client_secret

    if [ "${OPT_DRY_RUN}" = "true" ]; then
        log_info "[DRY-RUN] Would create /etc/open-bastion (0700)"
        log_info "[DRY-RUN] Would write /etc/open-bastion/openbastion.conf (0600)"
        log_info "[DRY-RUN]   client_id    = ${CLIENT_ID}"
        log_info "[DRY-RUN]   server_group = ${SERVER_GROUP}"
        log_info "[DRY-RUN]   client_secret= <$([ -n "${CLIENT_SECRET}" ] && echo 'set' || echo 'empty')>"
        log_info "[DRY-RUN] Would write /etc/ssh/open-bastion_ca.pub"
        if [ -n "@@KRL_B64@@" ]; then
            log_info "[DRY-RUN] Would write /etc/ssh/revoked_keys (KRL)"
        fi
        return 0
    fi

    mkdir -p /etc/open-bastion
    chmod 0700 /etc/open-bastion

    # Write openbastion.conf — substitute runtime-resolved values in the
    # embedded template. ##VAR## are runtime placeholders; @@VAR@@ were
    # already substituted by ob-builder at build time. sed is used
    # instead of bash ${var//pat/repl} because ## is a valid bash prefix
    # operator and would be misinterpreted inside ${ }.
    # Build the conf in memory with bash literal substitution — no sed.
    # This avoids any delimiter/escape gymnastics for secrets that may
    # contain |, /, &, \, or newlines.
    local _conf_template _conf_content
    _conf_template=$(cat << 'OB_CONF_EOF'
@@OPENBASTION_CONF_TEMPLATE@@
OB_CONF_EOF
)
    _conf_content="${_conf_template//##CLIENT_ID##/${CLIENT_ID}}"
    _conf_content="${_conf_content//##SERVER_GROUP##/${SERVER_GROUP}}"
    _conf_content="${_conf_content//##CLIENT_SECRET##/${CLIENT_SECRET}}"

    # Atomic write at 0600 root:root.
    local _conf_tmp
    _conf_tmp=$(mktemp /etc/open-bastion/openbastion.conf.XXXXXX)
    printf '%s\n' "${_conf_content}" > "${_conf_tmp}"
    chmod 0600 "${_conf_tmp}"
    chown root:root "${_conf_tmp}"
    mv -f "${_conf_tmp}" /etc/open-bastion/openbastion.conf
    log_info "Written: /etc/open-bastion/openbastion.conf (0600 root:root)"

    # Deposit SSH CA public key
    base64 -d > /etc/ssh/open-bastion_ca.pub.tmp << 'OB_CA_EOF'
@@CA_SSH_PUB_B64@@
OB_CA_EOF
    chmod 0644 /etc/ssh/open-bastion_ca.pub.tmp
    mv -f /etc/ssh/open-bastion_ca.pub.tmp /etc/ssh/open-bastion_ca.pub
    log_info "Written: /etc/ssh/open-bastion_ca.pub"

    # Verify CA fingerprint matches the build-time value (detects MITM / corruption)
    if command -v ssh-keygen >/dev/null 2>&1; then
        local _actual_fp
        _actual_fp=$(ssh-keygen -lf /etc/ssh/open-bastion_ca.pub 2>/dev/null | awk '{print $2}')
        if [ "${_actual_fp}" != "${CA_SSH_FINGERPRINT}" ]; then
            log_error "CA fingerprint mismatch!"
            log_error "  Expected: ${CA_SSH_FINGERPRINT}"
            log_error "  Got:      ${_actual_fp}"
            log_error "The embedded CA key does not match the expected fingerprint."
            log_error "This artifact may have been tampered with. Aborting."
            rm -f /etc/ssh/open-bastion_ca.pub
            exit 1
        fi
        log_info "CA fingerprint verified: ${_actual_fp}"
    else
        log_warn "ssh-keygen not found; skipping CA fingerprint verification"
    fi

    # Deposit KRL if present
    if [ -n "@@KRL_B64@@" ]; then
        base64 -d > /etc/ssh/revoked_keys.tmp << 'OB_KRL_EOF'
@@KRL_B64@@
OB_KRL_EOF
        chmod 0644 /etc/ssh/revoked_keys.tmp
        mv -f /etc/ssh/revoked_keys.tmp /etc/ssh/revoked_keys
        log_info "Written: /etc/ssh/revoked_keys (KRL)"
    fi
}

# ---------------------------------------------------------------------------
# Step 3 — Install open-bastion package
# ---------------------------------------------------------------------------

step_install() {
    log_step "3/5  Installing open-bastion package"

    if [ "${OPT_SKIP_INSTALL}" = "true" ]; then
        log_info "Skipping package install (--skip-install)"
        return 0
    fi

    if [ "${DISTRO}" = "rhel" ]; then
        if [ "${OPT_DRY_RUN}" = "true" ]; then
            log_info "[DRY-RUN] Would run: dnf install -y open-bastion"
        else
            dnf install -y open-bastion
        fi
        return
    fi

    if [ "${OPT_DRY_RUN}" = "true" ]; then
        log_info "[DRY-RUN] Would run: apt-get update && apt-get install -y open-bastion"
        return 0
    fi

    apt-get update -qq
    apt-get install -y open-bastion
    log_info "open-bastion package installed"
}

# ---------------------------------------------------------------------------
# Step 4 — Enroll (ob-enroll)
# ---------------------------------------------------------------------------

step_enroll() {
    log_step "4/5  Server enrollment (ob-enroll)"

    if [ "${OPT_SKIP_ENROLL}" = "true" ]; then
        log_info "Enrollment skipped (--skip-enroll)"
        return 0
    fi

    local _do_enroll=false
    case "${AUTO_ENROLL_SETUP}" in
        yes)   _do_enroll=true ;;
        no)    log_info "Enrollment skipped (auto_enroll=no in artifact)"; return 0 ;;
        prompt)
            if prompt_yn "Run ob-enroll now?"; then
                _do_enroll=true
            else
                log_info "Enrollment skipped by user"
                return 0
            fi
            ;;
    esac

    if [ "${_do_enroll}" != "true" ]; then
        return 0
    fi

    if [ "${OPT_DRY_RUN}" = "true" ]; then
        log_info "[DRY-RUN] Would run: OB_CLIENT_SECRET=<secret> /usr/sbin/ob-enroll -g '${SERVER_GROUP}'"
        return 0
    fi

    if [ ! -x /usr/sbin/ob-enroll ]; then
        log_warn "/usr/sbin/ob-enroll not found — open-bastion package may not be installed"
        log_warn "Run: ob-enroll -g '${SERVER_GROUP}' manually after installation"
        return 1
    fi

    local _enroll_opts=("-g" "${SERVER_GROUP}")
    if [ -n "${CLIENT_ID}" ]; then
        _enroll_opts+=("-c" "${CLIENT_ID}")
    fi
    if [ "${OPT_INSECURE}" = "true" ]; then
        _enroll_opts+=("-k")
    fi

    # Pass secret via env var, not CLI (keeps it out of /proc/<pid>/cmdline)
    if OB_CLIENT_SECRET="${CLIENT_SECRET}" /usr/sbin/ob-enroll "${_enroll_opts[@]}"; then
        log_info "Enrollment complete"
    else
        log_error "ob-enroll failed — check portal connectivity and credentials"
        log_error "You can retry manually: OB_CLIENT_SECRET=<secret> ob-enroll -g '${SERVER_GROUP}'"
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Step 5 — Role-specific setup
# ---------------------------------------------------------------------------

step_setup() {
    log_step "5/5  Role-specific setup (${TARGET_ROLE})"

    if [ "${OPT_SKIP_SETUP}" = "true" ]; then
        log_info "Setup skipped (--skip-setup)"
        return 0
    fi

    local _do_setup=false
    case "${AUTO_ENROLL_SETUP}" in
        yes)   _do_setup=true ;;
        no)    log_info "Setup skipped (auto_enroll_setup=no in artifact)"; return 0 ;;
        prompt)
            # standalone runs ob-bastion-setup (there is no ob-standalone-setup)
            local _setup_label="ob-${TARGET_ROLE}-setup"
            [ "${TARGET_ROLE}" = "standalone" ] && _setup_label="ob-bastion-setup"
            if prompt_yn "Run ${_setup_label} now?"; then
                _do_setup=true
            else
                log_info "Setup skipped by user"
                return 0
            fi
            ;;
    esac

    if [ "${_do_setup}" != "true" ]; then
        return 0
    fi

    case "${TARGET_ROLE}" in
        bastion|standalone)
            # bastion and standalone both run ob-bastion-setup: a standalone
            # host is simultaneously a bastion (inbound user SSH) and a backend
            # (target of forwarded sessions), and ob-bastion-setup applies the
            # full stack (this matches the Ansible standalone role).
            # ob-bastion-setup REQUIRES --portal and needs the group/client-id
            # to enroll. Passing them is mandatory: without --portal the setup
            # dies immediately ("Portal URL is required (-p/--portal)") and the
            # install never completes. The client_secret travels via
            # OB_CLIENT_SECRET (kept out of /proc/<pid>/cmdline). ob-enroll
            # already ran in step_enroll and wrote the token, so ob-bastion-setup
            # reuses it (no second device-code approval).
            local _setup_opts=("-p" "${PORTAL_URL}" "-g" "${SERVER_GROUP}")
            [ -n "${CLIENT_ID}" ] && _setup_opts+=("-c" "${CLIENT_ID}")
            [ "${PAM_MODE}" = "E" ] && _setup_opts+=("--max-security")
            [ "${OPT_INSECURE}" = "true" ] && _setup_opts+=("-k")
            [ "${ENABLE_HARDENING}" = "yes" ] && _setup_opts+=("--enable-hardening")
            [ "${ENABLE_AUDIT_TRACE}" = "yes" ] && _setup_opts+=("--enable-audit-trace")
            [ "${DISABLE_SESSION_RECORDER}" = "yes" ] && _setup_opts+=("--disable-session-recorder")
            if [ "${OPT_DRY_RUN}" = "true" ]; then
                log_info "[DRY-RUN] Would run: OB_CLIENT_SECRET=<secret> /usr/sbin/ob-bastion-setup ${_setup_opts[*]}"
                return 0
            fi
            if [ ! -x /usr/sbin/ob-bastion-setup ]; then
                log_warn "/usr/sbin/ob-bastion-setup not found"
                return 1
            fi
            OB_CLIENT_SECRET="${CLIENT_SECRET}" /usr/sbin/ob-bastion-setup "${_setup_opts[@]}"
            ;;
        backend)
            # Backends never record sessions, so --disable-session-recorder is
            # not applicable here; hardening / audit-trace stay opt-in.
            local _setup_opts=("-p" "${PORTAL_URL}" "-g" "${SERVER_GROUP}")
            [ -n "${CLIENT_ID}" ] && _setup_opts+=("-c" "${CLIENT_ID}")
            [ "${PAM_MODE}" = "E" ] && _setup_opts+=("--max-security")
            [ "${OPT_INSECURE}" = "true" ] && _setup_opts+=("-k")
            [ "${ENABLE_HARDENING}" = "yes" ] && _setup_opts+=("--enable-hardening")
            [ "${ENABLE_AUDIT_TRACE}" = "yes" ] && _setup_opts+=("--enable-audit-trace")
            if [ "${OPT_DRY_RUN}" = "true" ]; then
                log_info "[DRY-RUN] Would run: OB_CLIENT_SECRET=<secret> /usr/sbin/ob-backend-setup ${_setup_opts[*]}"
                return 0
            fi
            if [ ! -x /usr/sbin/ob-backend-setup ]; then
                log_warn "/usr/sbin/ob-backend-setup not found"
                return 1
            fi
            OB_CLIENT_SECRET="${CLIENT_SECRET}" /usr/sbin/ob-backend-setup "${_setup_opts[@]}"
            ;;
        *)
            log_warn "Unknown target role '${TARGET_ROLE}'; skipping role-specific setup"
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Final summary
# ---------------------------------------------------------------------------

print_summary() {
    echo ""
    echo "┌─────────────────────────────────────────────────────────┐"
    echo "│           Open Bastion Bootstrap Complete                │"
    echo "└─────────────────────────────────────────────────────────┘"
    echo ""
    echo "  Slug:        ${DEPLOYMENT_SLUG}"
    echo "  Scenario:    ${SCENARIO} (Mode ${PAM_MODE})"
    echo "  Role:        ${TARGET_ROLE}"
    echo "  Portal:      ${PORTAL_URL}"
    echo "  Client ID:   ${CLIENT_ID}"
    echo "  Server grp:  ${SERVER_GROUP}"
    echo "  CA key:      /etc/ssh/open-bastion_ca.pub"
    echo "  CA SHA256:   ${CA_SSH_FINGERPRINT}"
    if [ "${OPT_DRY_RUN}" = "true" ]; then
        echo ""
        echo "  [DRY-RUN] No changes were made to this system."
    fi
    echo ""
    echo "Next steps:"
    echo "  1. Verify SSH connectivity from a second terminal before closing this session"
    echo "  2. Check /etc/open-bastion/openbastion.conf is correct"
    if [ "${OPT_SKIP_ENROLL}" = "true" ]; then
        echo "  3. Run enrollment manually: ob-enroll -g '${SERVER_GROUP}'"
    fi
    echo ""
}

# ---------------------------------------------------------------------------
# Self-delete: remove the installer from disk on successful completion.
# Triggered when the build chose self_delete=yes, or when --self-delete is
# passed on the target. Skipped in --dry-run and when --no-self-delete is set.
# ---------------------------------------------------------------------------

step_self_delete() {
    local effective="${OPT_SELF_DELETE:-${SELF_DELETE_DEFAULT}}"
    [ "${effective}" = "yes" ] || return 0
    if [ "${OPT_DRY_RUN}" = "true" ]; then
        log_info "[DRY-RUN] Would self-delete installer ($0)"
        return 0
    fi
    local _self
    _self=$(realpath "$0" 2>/dev/null || echo "$0")
    if [ ! -f "${_self}" ]; then
        log_warn "Self-delete requested but cannot resolve installer path"
        return 0
    fi
    log_info "Removing installer from disk: ${_self}"
    rm -f -- "${_self}" || log_warn "Failed to remove ${_self} (check permissions)"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    parse_args "$@"

    # info subcommand is handled inside parse_args (calls cmd_info which exits)

    # Apply portal URL override (rare, mostly for testing)
    if [ -n "${OPT_PORTAL_URL}" ]; then
        PORTAL_URL="${OPT_PORTAL_URL}"
        log_warn "Portal URL overridden to: ${PORTAL_URL}"
    fi

    require_root
    detect_distro
    precheck

    echo ""
    echo "┌─────────────────────────────────────────────────────────┐"
    echo "│           Open Bastion Bootstrap                         │"
    echo "└─────────────────────────────────────────────────────────┘"
    echo ""
    echo "  Scenario: ${SCENARIO} (Mode ${PAM_MODE}) | Role: ${TARGET_ROLE}"
    echo "  Portal:   ${PORTAL_URL}"
    echo ""
    if [ "${OPT_DRY_RUN}" = "true" ]; then
        log_warn "DRY-RUN MODE — no changes will be made"
        echo ""
    fi

    step_repo
    step_config
    step_install
    step_enroll
    step_setup
    print_summary
    step_self_delete
}

main "$@"
