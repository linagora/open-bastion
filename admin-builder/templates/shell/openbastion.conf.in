# Open Bastion configuration
# Generated by ob-builder @@OB_BUILDER_VERSION@@ on @@BUILD_DATE@@
# Scenario: @@SCENARIO@@ (PAM Mode @@PAM_MODE@@) | Role: @@TARGET_ROLE@@

# SSO portal URL
portal_url = @@PORTAL_URL@@

# OIDC client credentials
# client_id and server_group are resolved at install time (see installer)
client_id = ##CLIENT_ID##
client_secret = ##CLIENT_SECRET##

# Server group (must match a group defined in LLNG pamAccessServerGroups)
server_group = ##SERVER_GROUP##

# Mode-specific settings — scenario: @@SCENARIO@@ (PAM Mode @@PAM_MODE@@)
@@MODE_SETTINGS@@

# Audit
log_level = warn
audit_enabled = true

@@BASTION_BACKEND_BLOCK@@
