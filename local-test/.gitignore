# Generated VM artefacts (large / machine-specific)
vm/*.qcow2
vm/*-seed.iso
vm/*.port
vm/debian-*-genericcloud-*.qcow2
# Built package + flat-repo index served to the VMs
sso/aptrepo/*.deb
sso/aptrepo/Packages
sso/aptrepo/Packages.gz
# Optional local SSO override (e.g. unreleased plugin mounts)
sso/docker-compose.override.yml
# Per-run workdir: generated roles/installers, logs, cookie, bastion-id
.work/
*.log
